# Titan007 数据采集系统 - 环境配置模板
# 复制此文件为 .env 并根据生产环境调整配置

# ==================== 基础配置 ====================
ENVIRONMENT=production
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/football_prediction

# ==================== Titan007 采集器配置 ====================

# API 配置
TITAN_BASE_URL=https://live.titan007.com/api/odds

# 重试配置
TITAN_MAX_RETRIES=3
TITAN_TIMEOUT=30.0

# HTTP连接池配置 (生产环境建议调高)
TITAN_MAX_CONNECTIONS=20
TITAN_MAX_KEEPALIVE_CONNECTIONS=10

# 重试策略配置
TITAN_RETRY_MULTIPLIER=0.5
TITAN_RETRY_MIN_WAIT=1.0
TITAN_RETRY_MAX_WAIT=10.0

# 限流配置 (根据目标网站承受能力调整)
TITAN_RATE_LIMIT_QPS=2.0
TITAN_RATE_LIMIT_BURST=1
TITAN_RATE_LIMIT_MAX_WAIT=30.0

# ==================== 数据库连接池配置 ====================

# 生产环境建议配置（根据并发量调整）
DB_POOL_POOL_SIZE=50
DB_POOL_MAX_OVERFLOW=100
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== 监控配置 ====================
# Prometheus 指标端口
METRICS_PORT=9000

# 健康检查端口
HEALTH_CHECK_PORT=8000