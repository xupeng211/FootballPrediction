    "style": "dark",
    "timezone": "browser",
    "editable": true,
    "graphTooltip": 0,
    "hideControls": false,
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "refresh": "30s",
    "templating": {
      "list": [
        {
          "current": {
            "text": "5m",
            "value": "5m"
          },
          "hide": 0,
          "includeAll": false,
          "label": "Auto",
          "multi": false,
          "name": "auto",
          "options": [
            {
              "selected": true,
              "text": "5m",
              "value": "5m"
            },
            {
              "selected": false,
              "text": "15m",
              "value": "15m"
            },
            {
              "selected": false,
              "text": "30m",
              "value": "30m"
