              "value": "24h"
            }
          ],
          "query": "5m",
          "refresh": 2,
          "skipUrlSync": false,
          "type": "interval"
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "API Requests Per Second (RPS)",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(football_prediction_http_requests_total[5m])",
            "refId": "A",
            "legendFormat": "{{method}} {{endpoint}}",
            "instant": false,
            "datasource": {
              "type": "prometheus",
              "uid": null
            }
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": []
          }
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "areas": {},
        "yaxes": [
          {
            "name": "Requests",
            "show": true,
            "min": null,
            "max": null,
            "logBase": 1,
            "format": "short"
          }
        ],
        "xaxes": [
          {
            "show": true,
            "mode": "time",
            "name": null,
            "values": [],
            "min": null,
            "max": null
          }
        ],
        "yaxes": [
          {
            "name": "Requests",
            "show": true,
            "min": null,
            "max": null,
            "logBase": 1,
            "format": "short"
          }
        ]
      },
      {
        "id": 2,
        "title": "API Response Time (P95 Latency)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(football_prediction_http_request_duration_seconds_bucket[5m]))",
            "refId": "A",
            "legendFormat": "{{method}} {{endpoint}}",
            "instant": false,
            "datasource": {
              "type": "prometheus",
              "uid": null
            }
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "table",
            "placement": "bottom",
            "calcs": []
          }
        },
        "lines": true,
        "fill": 0,
        "linewidth": 2,
        "areas": {},
        "yaxes": [
          {
            "name": "Latency (seconds)",
            "show": true,
            "min": null,
            "max": null,
            "logBase": 1,
            "format": "ms"
          }
        ],
        "xaxes": [
          {
            "show": true,
            "mode": "time",
            "name": null,
            "values": [],
            "min": null,
            "max": null
          }
        ],
        "yaxes": [
          {
            "name": "Latency (seconds)",
            "show": true,
            "min": null,
            "max": null,
            "logBase": 1,
            "format": "ms"
          }
        ]
      },
      {
        "id": 3,
        "title": "HTTP Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(football_prediction_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(football_prediction_http_requests_total[5m])) * 100",
            "refId": "A",
            "legendFormat": "Error Rate",
            "instant": false,
            "datasource": {
              "type": "prometheus",
              "uid": null
            }
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 8
        },
        "options": {
          "tooltip": {
            "mode": "single",
            "sort": "none"
          },
          "legend": {
            "displayMode": "value",
            "placement": "bottom",
            "calcs": []
          }
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "areas": {},
        "yaxes": [
          {
            "name": "Error Rate (%)",
            "show": true,
            "min": 0,
            "max": 100,
            "logBase": 1,
            "format": "percent"
          }
        ],
        "xaxes": [
          {
            "show": true,
            "mode": "time",
            "name": null,
            "values": [],
            "min": null,
            "max": null
          }
        ],
        "yaxes": [
          {
            "name": "Error Rate (%)",
            "show": true,
            "min": 0,
            "max": 100,
            "logBase": 1,
            "format": "percent"
          }
        ],
        "thresholds": [
          {
            "colorMode": "custom",
            "fill": true,
            "line": true,
            "op": "gt",
            "value": 5,
            "visible": true,
            "backgroundColor": "rgba(255, 96, 96, 0.2)",
            "yaxis": "Error Rate (%)"
          },
          {
            "colorMode": "custom",
            "fill": true,
            "line": true,
            "op": "gt",
            "value": 10,
            "visible": true,
            "backgroundColor": "rgba(255, 0, 0, 0.2)",
            "yaxis": "Error Rate (%)"
          }
        ]
      },
