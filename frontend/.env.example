# 前端环境配置示例
# 复制此文件为 .env 并根据需要修改配置

# API配置
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Mock认证配置（开发环境使用）
MOCK_USER_EMAIL=admin@football.com
MOCK_USER_PASSWORD=admin123

# Mock用户配置
MOCK_USERS={"admin":{"email":"admin@football.com","password":"admin123","username":"admin","role":"admin"},"user":{"email":"user@football.com","password":"user123","username":"user","role":"user"}}

# 开发模式配置
VITE_DEV_MODE=true
VITE_ENABLE_MOCK_FALLBACK=true

# 应用配置
VITE_APP_NAME=FootballPrediction
VITE_APP_VERSION=2.0.0