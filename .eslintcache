一归口管理\n * 严禁在业务代码中硬编码参数\n * @module config/constants\n * @version V4.46.2\n */",[0,137],"/**\n * V4.46.2 数据库配置与连接池管理\n * =================================\n *\n * 提供数据库连接池和重试逻辑\n * @module config/database\n * @version V4.46.2\n */",[0,327],"/**\n * V178 宸ュ巶绾ч厤缃腑蹇?(缁堟瀬寮哄寲鐗?\n * ==============================================\n *\n * 鎵€鏈夋敹鍓茬郴缁熺殑榄旀湳鏁板瓧缁熶竴褰掑彛绠＄悊\n * 涓ョ鍦ㄤ笟鍔′唬鐮佷腑纭紪鐮佷换浣曞弬鏁? *\n * V178 鍗囩骇:\n * - 鐔旀柇鍣ㄩ厤缃崌绾? 5 娆″け璐ヨЕ鍙? 60 绉掑喎鍗? * - 鎸囨暟閫€閬夸紭鍖? 1s -> 2s -> 4s (甯?卤20% 鎶栧姩)\n * @module config/factory_config\n * @version V178.0.0 (Ultimate Hardening Edition)\n */",[1583,1766],"/**\n     * 楠岃瘉鏁版嵁鏄惁鏈夋晥\n     * V175: 瀵逛簬鏈潵姣旇禌锛堟病鏈?stats锛変娇鐢ㄦ洿浣庣殑闃堝€?     * @param {object} rawData - 鍘熷鏁版嵁\n     * @param rawData\n     * @returns {{valid: boolean, reason?: string, size?: number}}\n     */",[5122,5222],"/**\n     * 鍒ゆ柇閿欒鏄惁鍙噸璇?     * @param {string} errorType - 閿欒绫诲瀷\n     * @param errorType\n     * @returns {boolean}\n     */",[7156,7306],"/**\n     * V173-OVERHAUL: 鏍规嵁 Worker ID 瀹岀編鏄犲皠鍒?22 涓鍙?     * @param {number} workerId - Worker 缂栧彿 (1-based)\n     * @param workerId\n     * @returns {number} 浠ｇ悊绔彛\n     */",[7491,7627],"/**\n     * V173-OVERHAUL: 鑾峰彇涓嬩竴涓彲鐢ㄧ鍙?(鐢ㄤ簬鏁呴殰鍒囨崲)\n     * @param {number} currentPort - 褰撳墠绔彛\n     * @returns {number} 涓嬩竴涓鍙?\n     */",[8328,8372],"/**\n     * V173-OVERHAUL: 鎵撳嵃绔彛姹犵姸鎬?\n     */",[16358,16437],"/**\n     * V173: 鑾峰彇闅忔満 User-Agent\n     * @returns {string} 闅忔満 UA 瀛楃涓?\n     */",[16546,16615],"/**\n     * V173: 鑾峰彇闅忔満瑙嗗彛灏哄\n     * @returns {object} 瑙嗗彛閰嶇疆\n     */",[17869,18026],"/**\n     * 妫€鏌ユ槸鍚﹀簲璇ヨЕ鍙戝喎鍗?     * @param {string} errorType - 閿欒绫诲瀷\n     * @param errorType\n     * @param {number} consecutiveFailures - 杩炵画澶辫触娆℃暟\n     * @returns {boolean}\n     */",[18296,18368],"/**\n     * 杩涘叆鍐峰嵈鐘舵€?     * @param {number} workerId - Worker ID\n     * @param workerId\n     */",[18757,18858],"/**\n     * 妫€鏌ユ槸鍚﹀湪鍐峰嵈涓?     * @param {number} workerId - Worker ID\n     * @param workerId\n     * @returns {boolean}\n     */",[19146,19274],"/**\n     * 鑾峰彇鍓╀綑鍐峰嵈鏃堕棿 (姣)\n     * @param {number} workerId - Worker ID\n     * @returns {number} 鍓╀綑姣鏁帮紝0 琛ㄧず涓嶅湪鍐峰嵈涓?\n     */",[22615,22714],"/**\n * 鑾峰彇闅忔満寤舵椂 (姣)\n * @param {number[]} range - [min, max] 鑼冨洿\n * @returns {number} 闅忔満姣鏁?\n */",[23339,23446],"/**\n * 闅忔満鏁扮敓鎴?(鑼冨洿)\n * @param {number} min - 鏈€灏忓€? * @param {number} max - 鏈€澶у€? * @returns {number}\n * @param max\n */",[0,471],"/**\n * 共享常量加载器 - V1.0.0\n * ======================\n *\n * 从 config/shared_constants.json 加载全局共享常量，确保 Python/Node.js 一致性。\n *\n * V4.17: 建立跨语言常量统一标准\n *\n * 使用方法:\n *   const { MATCH_STATUS, MATCH_OUTCOME, HOME_WIN } = require('../config/shared_constants');\n *\n *   // 比赛状态\n *   const status = MATCH_STATUS.FINISHED;  // \"finished\"\n *\n *   // 比赛结果\n *   const result = MATCH_OUTCOME.HOME_WIN;  // 2\n * @module config/shared_constants\n * @version V1.0.0\n * @since 2026-03-07\n */",[659,709],"/**\n * 加载共享常量（带缓存）\n * @returns {object} 共享常量对象\n */",[938,990],"/**\n * 重新加载常量（用于热更新）\n * @returns {object} 共享常量对象\n */",[4105,4159],"/**\n     * 转换为对象\n     * @returns {object} 概率对象\n     */",[20,245],"/**\n * TITAN-WAREHOUSE-IMPORT - 磁盘 JSON 全量入库\n * =============================================\n *\n * 将 /data/matches/*.json 批量导入 raw_match_data 表\n *\n * 用法:\n *   node scripts/ops/bulk_import_matches.js\n * @version V1.0.0\n */",[20,211],"/**\n * TITAN-WAREHOUSE-SMELT - 全量特征熔炼\n * =====================================\n *\n * 处理 raw_match_data 表中所有数据，无批次限制\n *\n * 用法:\n *   node scripts/ops/smelt_all_full.js\n * @version V1.0.0\n */",[0,184],"/**\n * OddsFluxDetector - 赔率背离监测器\n * ===================================\n *\n * TITAN V5.0 首个预测算法模块\n * 监测赔率异常波动，识别潜在价值投注机会\n * @module analysis/OddsFluxDetector\n * @version V5.0.0\n */",[201,464],"/**\n * 赔率背离检测结果\n * @typedef {object} DeviationResult\n * @property {boolean} hasDeviation - 是否存在背离\n * @property {number} deviationRate - 背离率 (0-1)\n * @property {string} direction - 背离方向 ('up' | 'down' | 'none')\n * @property {number} signalStrength - 信号强度 (0-1)\n */",[0,257],"/**\n * BaseExtractor - V4.0 特征提取器抽象基类\n * ========================================\n *\n * 建立特征提取的\"行业标准\"，强制规范所有特征维度的开发协议。\n * 所有具体提取器必须继承此类并实现抽象方法。\n * @module feature_engine/smelter/components/BaseExtractor\n * @version V4.0.0-MODULAR\n * @since 2026-03-14\n */",[938,938],"/**\n     *\n     */\n    ",[1209,1209],{"kind":"2722","justification":"2723"},[1502,2252],"/**\n     * 创建收割器实例\n     * @param {object} [config] - 配置选项\n     * @param {number} [config.maxWorkers] - 最大 Worker 数量\n     * @param {number} [config.minDelayMs] - 最小延时（毫秒）\n     * @param {number} [config.maxDelayMs] - 最大延时（毫秒）\n     * @param {number} [config.batchSize] - 每批次任务数\n     * @param {string} [config.leagueFilter] - 联赛过滤器\n     * @param {boolean} [config.dryRun] - 试运行模式\n     * @param {number} [config.maxRetries] - 最大重试次数\n     * @param {number} [config.retryDelayMs] - 重试延时（毫秒）\n     * @param {number} [config.maxSweepRounds] - 最大扫尾轮数\n     * @param {number} [config.targetSuccessRate] - 目标成功率\n     * @param {boolean} [config.verboseLogging=false] - 详细日志模式\n     * @param {boolean} [config.skipZombieCleanup=false] - 跳过僵尸进程清理（Swarm 模式）\n     */",[1502,2252],"/**\n     * 创建收割器实例\n     * @param {object} [config] - 配置选项\n     * @param {number} [config.maxWorkers] - 最大 Worker 数量\n     * @param {number} [config.minDelayMs] - 最小延时（毫秒）\n     * @param {number} [config.maxDelayMs] - 最大延时（毫秒）\n     * @param {number} [config.batchSize] - 每批次任务数\n     * @param {string} [config.leagueFilter] - 联赛过滤器\n     * @param {boolean} [config.dryRun] - 试运行模式\n     * @param {number} [config.maxRetries] - 最大重试次数\n     * @param {number} [config.retryDelayMs] - 重试延时（毫秒）\n     * @param {number} [config.maxSweepRounds] - 最大扫尾轮数\n     * @param {number} [config.targetSuccessRate] - 目标成功率\n     * @param {boolean} [config.verboseLogging] - 详细日志模式\n     * @param {boolean} [config.skipZombieCleanup=false] - 跳过僵尸进程清理（Swarm 模式）\n     */",[1502,2252],"/**\n     * 创建收割器实例\n     * @param {object} [config] - 配置选项\n     * @param {number} [config.maxWorkers] - 最大 Worker 数量\n     * @param {number} [config.minDelayMs] - 最小延时（毫秒）\n     * @param {number} [config.maxDelayMs] - 最大延时（毫秒）\n     * @param {number} [config.batchSize] - 每批次任务数\n     * @param {string} [config.leagueFilter] - 联赛过滤器\n     * @param {boolean} [config.dryRun] - 试运行模式\n     * @param {number} [config.maxRetries] - 最大重试次数\n     * @param {number} [config.retryDelayMs] - 重试延时（毫秒）\n     * @param {number} [config.maxSweepRounds] - 最大扫尾轮数\n     * @param {number} [config.targetSuccessRate] - 目标成功率\n     * @param {boolean} [config.verboseLogging] - 详细日志模式\n     * @param {boolean} [config.skipZombieCleanup] - 跳过僵尸进程清理（Swarm 模式）\n     */",[0,218],"/**\n * Dispatcher - 任务分派器\n * =========================\n *\n * 负责收割任务的分派与调度：\n * - Worker ID 计算与分配\n * - 批次逻辑处理\n * - CLI 参数解析\n * - 统计报告生成\n * @module infrastructure/harvesters/components/Dispatcher\n * @version V1.0.0\n */",[0,210],"/**\n * ErrorHandler - 高级错误审计器\n * ==============================\n *\n * 负责错误的分类、审计和重试决策：\n * - 错误类型分类\n * - 可重试性判断\n * - 错误统计与报告\n * @module infrastructure/harvesters/components/ErrorHandler\n * @version V1.0.0\n */",[4988,5032],"/**\n     * 检查是否为网络错误\n     * @param code\n     * @param message\n     * @private\n     */",[4988,5032],"/**\n     * 检查是否为网络错误\n     * @param code\n     * @param message\n     * @param code\n     * @param message\n     * @private\n     */",[5286,5330],"/**\n     * 检查是否为认证错误\n     * @param code\n     * @param message\n     * @private\n     */",[5286,5330],"/**\n     * 检查是否为认证错误\n     * @param code\n     * @param message\n     * @param code\n     * @param message\n     * @private\n     */",[5537,5581],"/**\n     * 检查是否为超时错误\n     * @param code\n     * @param message\n     * @private\n     */",[5537,5581],"/**\n     * 检查是否为超时错误\n     * @param code\n     * @param message\n     * @param code\n     * @param message\n     * @private\n     */",[5757,5801],"/**\n     * 检查是否为数据错误\n     * @param code\n     * @param message\n     * @private\n     */",[5757,5801],"/**\n     * 检查是否为数据错误\n     * @param code\n     * @param message\n     * @param code\n     * @param message\n     * @private\n     */",[0,206],"/**\n * Persistence - 数据持久化器\n * ==========================\n *\n * 负责数据的双保险持久化：\n * - 数据库存储（主存储，失败即抛错）\n * - 文件存储（辅助存储，失败不阻塞）\n * @module infrastructure/harvesters/components/Persistence\n * @version V1.0.0\n */",[0,235],"/**\n * StructuredLogger - V4.0 结构化日志器\n * ======================================\n *\n * 独立模块：输出 JSON 格式日志，便于 ELK 采集\n * 从 FeatureSmelter.js 剥离，支持独立测试\n * @module utils/StructuredLogger\n * @version V4.0.0-MODULAR\n * @since 2026-03-13\n */",[0,159],"/**\n * AutoAuthManager 异常路径测试\n * =============================\n *\n * 覆盖 AutoAuthManager 的异常处理逻辑\n * @module tests/unit/AutoAuthManager\n * @version V1.0.0\n */",{"kind":"2722","justification":"2723"},[339,339],"/**\n *\n */\n",[368,368],[0,236],"/**\n * Extractors_V4.test.js - V4.0 提取器高压测试套件\n * ==================================================\n *\n * 目标：行覆盖率 90%+\n * 重点：字段缺失、非法数值、深层嵌套 JSON 等极端破坏性场景\n * @module tests/unit/Extractors_V4\n * @version V4.0.0\n * @since 2026-03-14\n */",[2861,2884],"/**\n * 创建损坏/缺失字段的数据\n * @param type\n */",[5654,5654],[5706,5706],"/**\n         *\n         */\n        ",[5877,5877],[5917,5917],[6656,6656],[6710,6710],[6919,6919],[6959,6959],[8155,8155],[8211,8211],[8295,8295],[8366,8366],[392,392],[413,413],[646,646],[977,977],[0,206],"/**\n * ProductionHarvester 深度测试\n * =============================\n *\n * 目标：覆盖 run(), harvestWithRetry(), _harvestSingleMatch() 的所有逻辑分支\n * @module tests/unit/ProductionHarvester_Deep\n * @version V1.0.0\n */",[0,246],"/**\n * Smelter_Audit.test.js - FeatureSmelter 生产级压力审计\n * =====================================================\n *\n * 目标：暴露 FeatureSmelter.js (698行) 的测试盲区\n * 策略：压力测试 + 边界条件 + 异常情况\n * @module tests/unit/Smelter_Audit\n * @version V1.0.0-AUDIT\n */",[0,202],"/**\n * StructuredLogger.test.js - 