r used. Allowed unused args must match /^_/u.","'path' is defined but never used. Allowed unused args must match /^_/u.","'encoding' is defined but never used. Allowed unused args must match /^_/u.","Missing JSDoc @param \"dataPath\" description.","Missing JSDoc @param \"dataPath\" type.","Missing JSDoc @param \"filePath\" description.","Missing JSDoc @param \"filePath\" type.","Missing JSDoc @param \"sampleSize\" description.","Missing JSDoc @param \"sampleSize\" type.","Async method 'newContext' has no 'await' expression.","Async method 'wheel' has no 'await' expression.","Async method 'createContext' has no 'await' expression.","Async method 'loadBrowserStateCookies' has no 'await' expression.","Async method 'evaluate' has no 'await' expression.","Missing JSDoc @param \"port\" description.","Missing JSDoc @param \"port\" type.","no-global-assign","Read-only global 'require' should not be modified.","globalShouldNotBeModified",["2320"],"Invalid JSDoc @version: \"V197.0.0\".","'before' is assigned a value but never used.","'after' is assigned a value but never used.","'MOCK_MATCH_INFO' is assigned a value but never used.","'beforeEach' is assigned a value but never used.","Missing JSDoc @param \"leagues\" description.","Missing JSDoc @param \"leagues\" type.","Missing JSDoc @param \"seasons\" description.","Missing JSDoc @param \"seasons\" type.","Missing JSDoc @param \"minSizeBytes\" description.","Missing JSDoc @param \"minSizeBytes\" type.","Missing JSDoc @param \"source\" description.","Missing JSDoc @param \"source\" type.","'expectedPort' is assigned a value but never used.","'execAsync' is assigned a value but never used.","Async method 'checkCycle' has no 'await' expression.","Async method 'executeShutdown' has no 'await' expression.","Async method 'writeVictoryLog' has no 'await' expression.","Missing JSDoc @param \"html\" description.","Missing JSDoc @param \"html\" type.","'errorCount' is assigned a value but never used.","'validation' is assigned a value but never used.","'extractStatsFeatures' is assigned a value but never used.","'MOCK_NEXTJS_DATA' is assigned a value but never used.","Invalid JSDoc @version: \"V171.100\".","'afterEach' is assigned a value but never used.","'mockClient' is assigned a value but never used.","Async method 'query' has no 'await' expression.","'BrowserFactory' is assigned a value but never used.",[0,141],"/**\n * V4.46.2 统一常量配置\n * ====================\n *\n * 所有业务系统的魔术数字统一归口管理\n * 严禁在业务代码中硬编码参数\n * @module config/constants\n * @version V4.46.2\n */",[0,137],"/**\n * V4.46.2 数据库配置与连接池管理\n * =================================\n *\n * 提供数据库连接池和重试逻辑\n * @module config/database\n * @version V4.46.2\n */",[0,327],"/**\n * V178 宸ュ巶绾ч厤缃腑蹇?(缁堟瀬寮哄寲鐗?\n * ==============================================\n *\n * 鎵€鏈夋敹鍓茬郴缁熺殑榄旀湳鏁板瓧缁熶竴褰掑彛绠＄悊\n * 涓ョ鍦ㄤ笟鍔′唬鐮佷腑纭紪鐮佷换浣曞弬鏁? *\n * V178 鍗囩骇:\n * - 鐔旀柇鍣ㄩ厤缃崌绾? 5 娆″け璐ヨЕ鍙? 60 绉掑喎鍗? * - 鎸囨暟閫€閬夸紭鍖? 1s -> 2s -> 4s (甯?卤20% 鎶栧姩)\n * @module config/factory_config\n * @version V178.0.0 (Ultimate Hardening Edition)\n */",[1583,1766],"/**\n     * 楠岃瘉鏁版嵁鏄惁鏈夋晥\n     * V175: 瀵逛簬鏈潵姣旇禌锛堟病鏈?stats锛変娇鐢ㄦ洿浣庣殑闃堝€?     * @param {object} rawData - 鍘熷鏁版嵁\n     * @param rawData\n     * @returns {{valid: boolean, reason?: string, size?: number}}\n     */",[5122,5222],"/**\n     * 鍒ゆ柇閿欒鏄惁鍙噸璇?     * @param {string} errorType - 閿欒绫诲瀷\n     * @param errorType\n     * @returns {boolean}\n     */",[7156,7306],"/**\n     * V173-OVERHAUL: 鏍规嵁 Worker ID 瀹岀編鏄犲皠鍒?22 涓鍙?     * @param {number} workerId - Worker 缂栧彿 (1-based)\n     * @param workerId\n     * @returns {number} 浠ｇ悊绔彛\n     */",[7491,7627],"/**\n     * V173-OVERHAUL: 鑾峰彇涓嬩竴涓彲鐢ㄧ鍙?(鐢ㄤ簬鏁呴殰鍒囨崲)\n     * @param {number} currentPort - 褰撳墠绔彛\n     * @returns {number} 涓嬩竴涓鍙?\n     */",[8328,8372],"/**\n     * V173-OVERHAUL: 鎵撳嵃绔彛姹犵姸鎬?\n     */",[16358,16437],"/**\n     * V173: 鑾峰彇闅忔満 User-Agent\n     * @returns {string} 闅忔満 UA 瀛楃涓?\n     */",[16546,16615],"/**\n     * V173: 鑾峰彇闅忔満瑙嗗彛灏哄\n     * @returns {object} 瑙嗗彛閰嶇疆\n     */",[17869,18026],"/**\n     * 妫€鏌ユ槸鍚﹀簲璇ヨЕ鍙戝喎鍗?     * @param {string} errorType - 閿欒绫诲瀷\n     * @param errorType\n     * @param {number} consecutiveFailures - 杩炵画澶辫触娆℃暟\n     * @returns {boolean}\n     */",[18296,18368],"/**\n     * 杩涘叆鍐峰嵈鐘舵€?     * @param {number} workerId - Worker ID\n     * @param workerId\n     */",[18757,18858],"/**\n     * 妫€鏌ユ槸鍚﹀湪鍐峰嵈涓?     * @param {number} workerId - Worker ID\n     * @param workerId\n     * @returns {boolean}\n     */",[19146,19274],"/**\n     * 鑾峰彇鍓╀綑鍐峰嵈鏃堕棿 (姣)\n     * @param {number} workerId - Worker ID\n     * @returns {number} 鍓╀綑姣鏁帮紝0 琛ㄧず涓嶅湪鍐峰嵈涓?\n     */",[22615,22714],"/**\n * 鑾峰彇闅忔満寤舵椂 (姣)\n * @param {number[]} range - [min, max] 鑼冨洿\n * @returns {number} 闅忔満姣鏁?\n */",[23339,23446],"/**\n * 闅忔満鏁扮敓鎴?(鑼冨洿)\n * @param {number} min - 鏈€灏忓€? * @param {number} max - 鏈€澶у€? * @returns {number}\n * @param max\n */",[0,471],"/**\n * 共享常量加载器 - V1.0.0\n * ======================\n *\n * 从 config/shared_constants.json 加载全局共享常量，确保 Python/Node.js 一致性。\n *\n * V4.17: 建立跨语言常量统一标准\n *\n * 使用方法:\n *   const { MATCH_STATUS, MATCH_OUTCOME, HOME_WIN } = require('../config/shared_constants');\n *\n *   // 比赛状态\n *   const status = MATCH_STATUS.FINISHED;  // \"finished\"\n *\n *   // 比赛结果\n *   const result = MATCH_OUTCOME.HOME_WIN;  // 2\n * @module config/shared_constants\n * @version V1.0.0\n * @since 2026-03-07\n */",[659,709],"/**\n * 加载共享常量（带缓存）\n * @returns {object} 共享常量对象\n */",[938,990],"/**\n * 重新加载常量（用于热更新）\n * @returns {object} 共享常量对象\n */",[4105,4159],"/**\n     * 转换为对象\n     * @returns {object} 概率对象\n     */",{"kind":"2321","justification":"2322"},[1502,2252],"/**\n     * 创建收割器实例\n     * @param {object} [config] - 配置选项\n     * @param {number} [config.maxWorkers] - 最大 Worker 数量\n     * @param {number} [config.minDelayMs] - 最小延时（毫秒）\n     * @param {number} [config.maxDelayMs] - 最大延时（毫秒）\n     * @param {number} [config.batchSize] - 每批次任务数\n     * @param {string} [config.leagueFilter] - 联赛过滤器\n     * @param {boolean} [config.dryRun] - 试运行模式\n     * @param {number} [config.maxRetries] - 最大重试次数\n     * @param {number} [config.retryDelayMs] - 重试延时（毫秒）\n     * @param {number} [config.maxSweepRounds] - 最大扫尾轮数\n     * @param {number} [config.targetSuccessRate] - 目标成功率\n     * @param {boolean} [config.verboseLogging=false] - 详细日志模式\n     * @param {boolean} [config.skipZombieCleanup=false] - 跳过僵尸进程清理（Swarm 模式）\n     */",[1502,2252],"/**\n     * 创建收割器实例\n     * @param {object} [config] - 配置选项\n     * @param {number} [config.maxWorkers] - 最大 Worker 数量\n     * @param {number} [config.minDelayMs] - 最小延时（毫秒）\n     * @param {number} [config.maxDelayMs] - 最大延时（毫秒）\n     * @param {number} [config.batchSize] - 每批次任务数\n     * @param {string} [config.leagueFilter] - 联赛过滤器\n     * @param {boolean} [config.dryRun] - 试运行模式\n     * @param {number} [config.maxRetries] - 最大重试次数\n     * @param {number} [config.retryDelayMs] - 重试延时（毫秒）\n     * @param {number} [config.maxSweepRounds] - 最大扫尾轮数\n     * @param {number} [config.targetSuccessRate] - 目标成功率\n     * @param {boolean} [config.verboseLogging] - 详细日志模式\n     * @param {boolean} [config.skipZombieCleanup=false] - 跳过僵尸进程清理（Swarm 模式）\n     */",[1502,2252],"/**\n     * 创建收割器实例\n     * @param {object} [config] - 配置选项\n     * @param {number} [config.maxWorkers] - 最大 Worker 数量\n     * @param {number} [config.minDelayMs] - 最小延时（毫秒）\n     * @param {number} [config.maxDelayMs] - 最大延时（毫秒）\n     * @param {number} [config.batchSize] - 每批次任务数\n     * @param {string} [config.leagueFilter] - 联赛过滤器\n     * @param {boolean} [config.dryRun] - 试运行模式\n     * @param {number} [config.maxRetries] - 最大重试次数\n     * @param {number} [config.retryDelayMs] - 重试延时（毫秒）\n     * @param {number} [config.maxSweepRounds] - 最大扫尾轮数\n     * @param {number} [config.targetSuccessRate] - 目标成功率\n     * @param {boolean} [config.verboseLogging] - 详细日志模式\n     * @param {boolean} [config.skipZombieCleanup] - 跳过僵尸进程清理（Swarm 模式）\n     */",{"kind":"2321","justification":"2322"},"directive",""]