n     * @param matches\n     * @param teamName\n     * @param matches\n     * @param teamName\n     * @private\n     */",[12211,12254],"/**\n     * 计算对局平局指标\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @private\n     */",[12211,12254],"/**\n     * 计算对局平局指标\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @private\n     */",[12211,12254],"/**\n     * 计算对局平局指标\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @private\n     */",[12211,12254],"/**\n     * 计算对局平局指标\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @param home\n     * @param away\n     * @param homeTeam\n     * @param awayTeam\n     * @private\n     */",[14201,14201],[14616,14616],[1782,1782],[8251,8348],"/**\n     * 计算射门转化率\n     * shot_conversion = shots_on_target / shots_total\n     * @param matches\n     * @param teamName\n     * @private\n     */",[8251,8348],"/**\n     * 计算射门转化率\n     * shot_conversion = shots_on_target / shots_total\n     * @param matches\n     * @param teamName\n     * @param matches\n     * @param teamName\n     * @private\n     */",[9196,9308],"/**\n     * 计算绝佳机会转化率\n     * big_chance_conversion = goals_from_big_chances / big_chances\n     * @param matches\n     * @param teamName\n     * @private\n     */",[9196,9308],"/**\n     * 计算绝佳机会转化率\n     * big_chance_conversion = goals_from_big_chances / big_chances\n     * @param matches\n     * @param teamName\n     * @param matches\n     * @param teamName\n     * @private\n     */",[10280,10457],"/**\n     * 计算终结效率 (Finishing Efficiency)\n     * finishing_efficiency = actual_goals / expected_goals\n     * > 1.0: 超常发挥，把握机会能力强\n     * < 1.0: 浪费机会，临门一脚欠佳\n     * @param matches\n     * @param teamName\n     * @private\n     */",[10280,10457],"/**\n     * 计算终结效率 (Finishing Efficiency)\n     * finishing_efficiency = actual_goals / expected_goals\n     * > 1.0: 超常发挥，把握机会能力强\n     * < 1.0: 浪费机会，临门一脚欠佳\n     * @param matches\n     * @param teamName\n     * @param matches\n     * @param teamName\n     * @private\n     */",[11340,11488],"/**\n     * 计算防守稳固性\n     * defensive_solidity = expected_conceded / actual_conceded\n     * > 1.0: 防守优于预期\n     * < 1.0: 防守差于预期\n     * @param matches\n     * @param teamName\n     * @private\n     */",[11340,11488],"/**\n     * 计算防守稳固性\n     * defensive_solidity = expected_conceded / actual_conceded\n     * > 1.0: 防守优于预期\n     * < 1.0: 防守差于预期\n     * @param matches\n     * @param teamName\n     * @param matches\n     * @param teamName\n     * @private\n     */",[12479,12612],"/**\n     * 计算压迫效率 (Pressing Efficiency)\n     * 基于 PPDA (Passes Per Defensive Action) 计算\n     * PPDA越低 = 压迫越积极\n     * @param matches\n     * @param teamName\n     * @private\n     */",[12479,12612],"/**\n     * 计算压迫效率 (Pressing Efficiency)\n     * 基于 PPDA (Passes Per Defensive Action) 计算\n     * PPDA越低 = 压迫越积极\n     * @param matches\n     * @param teamName\n     * @param matches\n     * @param teamName\n     * @private\n     */",[13397,13438],"/**\n     * 计算对比特征\n     * @param home\n     * @param away\n     * @private\n     */",[13397,13438],"/**\n     * 计算对比特征\n     * @param home\n     * @param away\n     * @param home\n     * @param away\n     * @private\n     */",[14642,14642],[15091,15091],[0,242],"/**\n * L3Writer - V5.2 L3 特征写入器\n * ==============================\n *\n * 负责 l3_features 表的批量写入与冲突处理（UPSERT）。\n * 管理事务，确保特征数据的一致性。\n * @module feature_engine/smelter/component