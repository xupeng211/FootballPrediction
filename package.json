{
  "name": "footballprediction-v174",
  "version": "175.0.0-stable",
  "description": "V174 模块化收割引擎 - Master-Worker 架构 + 12 个独立模块",
  "private": true,
  "scripts": {
    "start": "node scripts/ops/harvest_fleet_master.js",
    "harvest": "node scripts/ops/harvest_fleet_master.js",
    "harvest:limit": "node scripts/ops/harvest_fleet_master.js",
    "watch": "node scripts/ops/monitor_dashboard.js",
    "report": "node scripts/ops/asset_report.js",
    "status": "node scripts/ops/monitor_dashboard.js",
    "diagnose": "node scripts/ops/diagnostic_experiment.js",
    "install-browsers": "playwright install chromium",
    "test": "node --test tests/unit/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/unit/*.test.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules/",
    "lint:fix": "eslint . --ext .js --ignore-pattern node_modules/ --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "lint:python": "ruff check src/",
    "format:python": "ruff format src/",
    "qa": "npm run lint && npm run test:unit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "jsdom": "^27.4.0",
    "p-limit": "^3.1.0",
    "pg": "^8.17.2",
    "playwright": "^1.57.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "verbose": true
  },
  "author": "V174 Engineering Team",
  "license": "MIT"
}
