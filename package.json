{
  "name": "footballprediction-v172",
  "version": "172.1.0",
  "description": "V172 数据收割引擎 - 原始 JSON 高质量入库系统",
  "private": true,
  "scripts": {
    "start": "node scripts/ops/v171_scheduler.js",
    "harvest": "node scripts/ops/v171_mass_harvest.js",
    "harvest:quick": "node scripts/ops/v171_quick_harvest.js",
    "harvest:limit": "node scripts/ops/v171_mass_harvest.js --limit",
    "harvest:v172": "node scripts/ops/harvest_fleet_master.js",
    "extract-urls": "node scripts/ops/v171_real_url_extractor.js",
    "scheduler": "node scripts/ops/v171_scheduler.js",
    "install-browsers": "playwright install chromium",
    "sync": "node scripts/ops/v42_660_node_temporal_sync.js",
    "diagnose": "node diagnose_json_path.js",
    "test": "node --test tests/unit/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/unit/*.test.js",
    "test:v171": "node --test tests/test_v171_database_config.js",
    "test:python": "pytest tests/test_v171_*.py -v",
    "lint": "eslint . --ext .js --ignore-pattern node_modules/",
    "lint:fix": "eslint . --ext .js --ignore-pattern node_modules/ --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "lint:python": "ruff check src/",
    "format:python": "ruff format src/",
    "qa": "npm run lint && npm run test:unit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "jsdom": "^27.4.0",
    "p-limit": "^3.1.0",
    "pg": "^8.17.2",
    "playwright": "^1.57.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "scripts/ops/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "verbose": true
  },
  "author": "V172 Engineering Team",
  "license": "MIT"
}
