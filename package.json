{
  "name": "footballprediction-v178",
  "version": "178.0.0-stable",
  "description": "V178 L1 Discovery Engine - 工业级赛程发现模块",
  "private": true,
  "scripts": {
    "start": "node scripts/ops/run_production.js",
    "seed": "node scripts/ops/seed_fixtures.js",
    "seed:all": "node scripts/ops/seed_fixtures.js --all",
    "smelt": "node scripts/ops/smelt_all.js",
    "install-browsers": "playwright install chromium",
    "test": "node --test tests/unit/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:l1": "node --test tests/unit/FixtureSeeder.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/unit/*.test.js",
    "lint": "eslint . --ext .js --ignore-pattern node_modules/",
    "lint:fix": "eslint . --ext .js --ignore-pattern node_modules/ --fix",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "lint:python": "ruff check src/",
    "format:python": "ruff format src/",
    "qa": "npm run lint && npm run test:unit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "jsdom": "^27.4.0",
    "p-limit": "^3.1.0",
    "pg": "^8.17.2",
    "playwright": "^1.57.0",
    "playwright-stealth": "^0.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "verbose": true
  },
  "author": "V174 Engineering Team",
  "license": "MIT"
}
