# 足球预测系统环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ==========================================
# 数据库配置
# ==========================================
# 数据库连接配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=football_prediction

# 完整数据库URL (可选，如果提供则覆盖上述配置)
# DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/football_prediction

# ==========================================
# 数据库连接池配置
# ==========================================
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_MAX_QUERIES=50000
DB_POOL_MAX_INACTIVE_LIFETIME=300.0

# 超时配置
DB_TIMEOUT=60.0
DB_COMMAND_TIMEOUT=30.0

# 健康检查配置
DB_HEALTH_CHECK_INTERVAL=30.0
DB_HEALTH_CHECK_TIMEOUT=5.0

# 重连配置
DB_MAX_RETRIES=3
DB_RETRY_DELAY=1.0

# ==========================================
# FotMob API配置
# ==========================================
# API基础URL
FOTMOB_BASE_URL=https://www.fotmob.com/api

# 鉴权头配置 (必需)
FOTMOB_X_MAS_HEADER=your_x_mas_header_here
FOTMOB_X_FOO_HEADER=your_x_foo_header_here

# 请求配置
FOTMOB_MAX_RETRIES=3
FOTMOB_TIMEOUT=30
FOTMOB_DELAY_BETWEEN_REQUESTS=2.0

# 数据采集配置
FOTMOB_BATCH_SIZE=50
FOTMOB_MAX_CONCURRENT_REQUESTS=10

# ==========================================
# 应用配置
# ==========================================
# 应用基础信息
APP_NAME=FootballPrediction
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=false

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# 性能配置
APP_REQUEST_TIMEOUT=300
APP_MAX_REQUEST_SIZE=10485760

# 安全配置
APP_SECRET_KEY=your-very-long-secret-key-change-in-production-environment
APP_ALLOWED_HOSTS=["*"]

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE_PATH=/app/logs/app.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5
LOG_ENABLE_JSON=false
LOG_ENABLE_CORRELATION_ID=true

# ==========================================
# 容器环境特定配置
# ==========================================
# 时区设置
TZ=UTC

# Python环境
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
PYTHONPATH=/app/src