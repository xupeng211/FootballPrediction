# ==============================================================================
# FootballPrediction V105.0 - 环境变量配置模板
# ==============================================================================
# 使用说明:
#   1. 复制此文件为 .env: cp config_template.env .env
#   2. 修改标有 [REQUIRED] 的敏感配置项
#   3. 生产环境必须修改所有默认密码和密钥
#   4. 使用 FOOTBALL_ 前缀可覆盖配置 (例: FOOTBALL_DB_HOST)
# ==============================================================================

# ------------------------------------------------------------------------------
# 应用基础配置
# ------------------------------------------------------------------------------
ENVIRONMENT=development              # development|testing|staging|production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-minimum-32-characters-long  # [REQUIRED]

# ------------------------------------------------------------------------------
# 服务配置
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ------------------------------------------------------------------------------
# 数据库配置 [REQUIRED]
# ------------------------------------------------------------------------------
DB_HOST=localhost                    # Docker 环境使用 'db'
DB_PORT=5432
DB_NAME=football_db
DB_USER=football_user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION  # [REQUIRED]
DB_SSL_MODE=false
DB_POOL_SIZE=10

# ------------------------------------------------------------------------------
# Redis 配置
# ------------------------------------------------------------------------------
REDIS_HOST=localhost                 # Docker 环境使用 'redis'
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# FotMob API 配置
# ------------------------------------------------------------------------------
FOTMOB_BASE_URL=https://www.fotmob.com/api
# FOTMOB_X_MAS_HEADER=
# FOTMOB_X_FOO_HEADER=

# ------------------------------------------------------------------------------
# OddsPortal API 配置
# ------------------------------------------------------------------------------
ODDSPORTAL_BASE_URL=https://www.oddsportal.com
ODDSPORTAL_TIMEOUT_MS=30000
ODDSPORTAL_RETRY_ATTEMPTS=3

# ------------------------------------------------------------------------------
# 模型配置
# ------------------------------------------------------------------------------
MODEL_PATH=model_zoo/v26.8_epl_production.pkl
MODEL_VERSION=v26.8

# ------------------------------------------------------------------------------
# 业务逻辑配置
# ------------------------------------------------------------------------------
DEFAULT_CONFIDENCE_THRESHOLD=0.6
MIN_EDGE=7.0
MIN_CONFIDENCE=45.0
TARGET_ROI=13.35

# ------------------------------------------------------------------------------
# 数据采集配置 (V56.0 Production Harvester)
# ------------------------------------------------------------------------------
HARVEST_BATCH_SIZE=50
HARVEST_DELAY_SECONDS=1.0
HARVESTER_BATCH_INTERVAL=30
HARVESTER_BATCH_REST_SECONDS=60
HARVESTER_CONNECTION_ERROR_THRESHOLD=3
HARVESTER_CONNECTION_COOLDOWN_SECONDS=300

# ------------------------------------------------------------------------------
# 网络弹性协议 (V100.0)
# ------------------------------------------------------------------------------
MAX_PARALLEL_WORKERS=4
MIN_REQUEST_DELAY=3.0
MAX_REQUEST_DELAY=7.0
MAX_RETRY_ATTEMPTS=3
BASE_RETRY_DELAY=2.0

# ------------------------------------------------------------------------------
# 监控配置
# ------------------------------------------------------------------------------
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false

# ------------------------------------------------------------------------------
# Docker 环境标识 (自动设置)
# ------------------------------------------------------------------------------
DOCKER_ENV=false                     # true|false

# ------------------------------------------------------------------------------
# 开发工具配置 (仅开发环境)
# ------------------------------------------------------------------------------
PGADMIN_EMAIL=admin@football.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
REDIS_CMD_PORT=8081

# ==============================================================================
# 安全检查清单
# ==============================================================================
# [ ] 生产环境已修改 DB_PASSWORD
# [ ] 生产环境已修改 SECRET_KEY (至少32字符)
# [ ] 生产环境已关闭 DEBUG
# [ ] 生产环境已启用 DB_SSL_MODE
# [ ] 已配置 ALLOWED_HOSTS
# ==============================================================================
