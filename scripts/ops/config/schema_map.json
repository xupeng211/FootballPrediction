{
  "version": "V43.100",
  "description": "Centralized selector configuration for temporal data extraction",
  "last_updated": "2026-01-24",
  "selectors": {
    "row_identification": {
      "formula_a": {
        "name": "Provider Row Selector",
        "selector": "div[class*='border-black-borders'][class*='flex'][class*='h-9']",
        "description": "Main container for provider rows",
        "fallback": "tr[data-provider], table tr, tbody tr"
      }
    },
    "interaction_trigger": {
      "formula_b": {
        "name": "Hover Trigger Selector",
        "selector": "div.flex-center.flex-col.font-bold",
        "description": "Element that triggers tooltip on hover",
        "fallback": "[data-odd], [data-value], span[class*='odd']"
      }
    },
    "tooltip_detection": {
      "anchor": {
        "name": "Tooltip Anchor",
        "selector": "h3:text('Odds movement')",
        "description": "Stable header element that confirms tooltip presence"
      },
      "container": {
        "name": "Tooltip Container",
        "selector": "div[class*='tooltip']",
        "fallback": "div[class*='movement'], div[class*='popover'], [role='tooltip']",
        "description": "Main tooltip container element"
      }
    },
    "data_extraction": {
      "structural_anchors": {
        "name": "Row Container (Relative Path)",
        "description": "Navigates from anchor to data rows using relative positioning",
        "strategy": "nth-child",
        "note": "Uses relative positioning from anchor rather than class names"
      },
      "time_field": {
        "name": "Timestamp Cell",
        "pattern": "text-[10px].font-normal",
        "description": "Time format: '24 Jan, 10:00' or 'Jan 24, 10:00'",
        "regex": "\\d{1,2}\\s+\\w+\\.?\\s*,?\\s+\\d{1,2}:\\d{2}"
      },
      "value_field": {
        "name": "Odds Value Cell",
        "pattern": "text-[10px].font-bold",
        "description": "Decimal odds value",
        "regex": "\\d+\\.\\d+",
        "validation": "value > 1 && value < 100"
      },
      "delta_field": {
        "name": "Change Delta Cell",
        "pattern": "text-[10px].font-bold.text-green-dark",
        "description": "Optional change indicator (e.g., '+0.05')",
        "optional": true
      }
    }
  },
  "retry_config": {
    "hover": {
      "max_retries": 3,
      "base_delay": 500,
      "max_delay": 5000,
      "backoff_multiplier": 2,
      "hover_wait": 2000
    }
  },
  "rate_limiting": {
    "concurrency": 2,
    "delay": 800,
    "max_providers": 2
  },
  "target_providers": {
    "primary": ["pinnacle", "bet365"],
    "secondary": ["sbobet", "william hill", "ladbrokes"]
  }
}
