{
  "version": "V51.000",
  "description": "Enhanced selector configuration with stable attributes for temporal data extraction",
  "last_updated": "2026-01-25",
  "notes": [
    "V51.000: Prioritizes stable attributes (data-testid, aria-label) over volatile class names",
    "V51.000: Supports dual-point sampling (Initial + Current) contract validation",
    "V51.000: Includes penetration load config for source IDs [16, 18, 22, 25, 30]"
  ],
  "selectors": {
    "row_identification": {
      "formula_a": {
        "name": "Provider Row Selector (Stable Attributes)",
        "selector_strategy": "priority_fallback",
        "priority_selectors": [
          {
            "type": "data-testid",
            "selector": "[data-testid=\"over-under-expanded-row\"]",
            "weight": 100,
            "description": "React/Vue test ID (highest priority)"
          },
          {
            "type": "data-testid",
            "selector": "[data-testid=\"game-row\"]",
            "weight": 95,
            "description": "React/Vue test ID for list view"
          },
          {
            "type": "aria-label",
            "selector": "[aria-label*=\"provider\"], [aria-label*=\"odds\"]",
            "weight": 90,
            "description": "ARIA label for accessibility"
          },
          {
            "type": "data-entity-id",
            "selector": "[data-entity-id], [data-provider-id], [data-source-id]",
            "weight": 85,
            "description": "Entity ID attribute"
          }
        ],
        "fallback_selectors": [
          "div[class*=\"border-black-borders\"][class*=\"flex\"][class*=\"h-9\"]",
          "tr[data-provider]",
          "table tr",
          "tbody tr"
        ],
        "description": "Main container for provider rows with stable attribute priority"
      }
    },
    "interaction_trigger": {
      "formula_b": {
        "name": "Hover Trigger Selector (Stable Attributes)",
        "selector_strategy": "priority_fallback",
        "priority_selectors": [
          {
            "type": "data-testid",
            "selector": "[data-testid=\"interaction-trigger\"]",
            "weight": 100
          },
          {
            "type": "data-testid",
            "selector": "[data-testid*=\"hover\"], [data-testid*=\"trigger\"]",
            "weight": 90
          },
          {
            "type": "aria-label",
            "selector": "[aria-label=\"Show odds movement\"], [aria-label*=\"odds\"], [aria-label*=\"chart\"]",
            "weight": 85
          }
        ],
        "fallback_selectors": [
          "div.flex-center.flex-col.font-bold",
          "[data-odd], [data-value]",
          "span[class*=\"odd\"]"
        ],
        "description": "Element that triggers tooltip on hover"
      }
    },
    "tooltip_detection": {
      "anchor": {
        "name": "Tooltip Anchor (Stable)",
        "selector": "h3:text('Odds movement')",
        "description": "Stable header element that confirms tooltip presence"
      },
      "container": {
        "name": "Tooltip Container (Stable)",
        "selector_strategy": "priority_fallback",
        "priority_selectors": [
          {
            "type": "data-testid",
            "selector": "[data-testid=\"tooltip-container\"], [data-testid=\"odds-movement-tooltip\"]",
            "weight": 100
          },
          {
            "type": "role",
            "selector": "[role=\"tooltip\"], [role=\"dialog\"]",
            "weight": 90
          },
          {
            "type": "aria-label",
            "selector": "[aria-label*=\"tooltip\"], [aria-label*=\"movement\"]",
            "weight": 85
          }
        ],
        "fallback_selectors": [
          "div.height-content.absolute.bottom-\\[30px\\]"
        ],
        "fallback_strategy": "Use h3:text('Odds movement') + closest() approach instead",
        "description": "V51.000: Tooltip container with stable attribute priority"
      }
    },
    "data_extraction": {
      "structural_anchors": {
        "name": "Row Container (Relative Path)",
        "description": "Navigates from anchor to data rows using relative positioning",
        "strategy": "nth-child",
        "note": "Uses relative positioning from anchor rather than class names"
      },
      "time_field": {
        "name": "Timestamp Cell (Stable)",
        "selector_strategy": "content_based",
        "patterns": [
          "text-[10px].font-normal",
          "[datetime]",
          "[data-timestamp]"
        ],
        "description": "Time format: '24 Jan, 10:00' or 'Jan 24, 10:00'",
        "regex": "\\d{1,2}\\s+\\w+\\.?\\s*,?\\s+\\d{1,2}:\\d{2}"
      },
      "value_field": {
        "name": "Odds Value Cell (Stable)",
        "selector_strategy": "content_based",
        "patterns": [
          "text-[10px].font-bold",
          "[data-odd]",
          "[data-value]"
        ],
        "description": "Decimal odds value",
        "regex": "\\d+\\.\\d+",
        "validation": "value > 1 && value < 100"
      },
      "delta_field": {
        "name": "Change Delta Cell (Optional)",
        "selector_strategy": "content_based",
        "patterns": [
          "text-[10px].font-bold.text-green-dark",
          "[data-delta]"
        ],
        "description": "Optional change indicator (e.g., '+0.05')",
        "optional": true
      },
      "dual_point_sampling": {
        "name": "Dual-Point Sampling Markers",
        "initial_marker": "Opening odds:",
        "current_marker": "First numeric value",
        "delta_marker": "+",
        "required": true,
        "description": "V51.000: Contract validation requires both Initial and Current values"
      }
    }
  },
  "retry_config": {
    "hover": {
      "max_retries": 3,
      "base_delay": 500,
      "max_delay": 5000,
      "backoff_multiplier": 2,
      "hover_wait": 2000
    },
    "penetration_load": {
      "enabled": true,
      "max_retries": 3,
      "scroll_timeout": 5000,
      "content_timeout": 10000,
      "min_content_length": 1
    }
  },
  "contract_validation": {
    "enabled": true,
    "required_samples": 2,
    "min_sample_density": 2,
    "max_fallback_attempts": 2,
    "sample_interval": 500,
    "max_wait_time": 5000
  },
  "rate_limiting": {
    "concurrency": 2,
    "delay": 800,
    "max_providers": 5
  },
  "target_source_ids": {
    "primary": [16, 18, 22, 25, 30],
    "description": "V51.000: Target source IDs requiring penetration load special handling",
    "penetration_load_enabled": true
  },
  "target_providers": {
    "primary": [
      "william-hill",
      "betway",
      "188bet",
      "bet365",
      "pinnacle"
    ],
    "secondary": [
      "sbobet",
      "william hill",
      "ladbrokes"
    ]
  },
  "output_protocol": {
    "format": "JSON_RESULT",
    "version": "V51.000",
    "enabled": true,
    "description": "[JSON_RESULT]{...}[JSON_RESULT] protocol"
  },
  "dom_audit": {
    "enabled": true,
    "stable_attributes": [
      "data-testid",
      "data-provider",
      "data-entity-id",
      "aria-label",
      "role"
    ],
    "random_class_patterns": [
      "data-v-[a-f0-9]{6,}",
      "_\\d+[a-f0-9]{4,}",
      "css-[a-z0-9]{8,}"
    ]
  }
}
