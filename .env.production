# ==================== Football Prediction System - 生产环境配置 ====================
#
# 重要提醒：此文件包含生产环境敏感信息，请勿提交到版本控制系统
#

# 环境标识
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ==================== 数据库配置 ====================
# 生产数据库连接池优化配置
DATABASE_URL=postgresql+asyncpg://postgres:StrongProdPassword123@db:5432/football_prediction
DB_HOST=db
DB_PORT=5432
DB_NAME=football_prediction
DB_USER=postgres
DB_PASSWORD=StrongProdPassword123

# 数据库连接池配置 (生产环境优化)
DB_POOL_POOL_SIZE=50
DB_POOL_MAX_OVERFLOW=100
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600

# ==================== Redis缓存配置 ====================
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=RedisProdPassword123456

# ==================== API服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ==================== 安全配置 ====================
# 生产环境必须使用强密钥
SECRET_KEY=ProdSecretKeyMinimum32CharactersLongFootball2024
JWT_SECRET_KEY=ProdJWTSecretKeyMinimum32CharactersLongFootball2024Secure
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== 外部服务配置 ====================
# FotMob API 生产密钥 (已配置最新有效密钥)
FOTMOB_X_MAS_TOKEN=eyJib2R5Ijp7InVybCI6Ii9hcGkvZGF0YS9sZWFndWVzP2lkPTg3IiwiY29kZSI6MTc2NTEyMTc0OTUyNSwiZm9vIjoicHJvZHVjdGlvbjo0MjhmYTAzNTVmMDljYTg4Zjk3YjE3OGViNWE3OWVmMGNmYmQwZGZjIn0sInNpZ25hdHVyZSI6IkIwQzkyMzkxMTM4NTdCNUFBMjk5Rjc5M0QxOTYwRkZCIn0=
FOTMOB_X_FOO_TOKEN=eyJmb28iOiJwcm9kdWN0aW9uOjQyOGZhMDM1NWYwOWNhODhmOTdiMTc4ZWI1YTc5ZWYwY2ZiZDBkZmMiLCJ0aW1lc3RhbXAiOjE3NjUxMjE4MTJ9

# 足球数据API配置
FOOTBALL_DATA_API_KEY=ed809154dc1f422da46a18d8961a98a0
EXTERNAL_API_TIMEOUT=30
EXTERNAL_API_RETRIES=3

# ==================== 监控配置 ====================
# Prometheus 指标配置
ENABLE_METRICS=true
METRICS_PORT=9090

# Grafana 管理配置
GRAFANA_ADMIN_PASSWORD=GrafanaProdSecurePassword2024

# ==================== 性能优化配置 ====================
# 关闭开发模式特性
HOT_RELOAD=false
AUTO_RESTART=false

# 生产环境限流配置
RATE_LIMIT_QPS=100
RATE_LIMIT_BURST=50

# ==================== 邮件告警配置 ====================
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=alerts@football-prediction.com
SMTP_PASSWORD=EmailAppPasswordForProduction
SMTP_FROM_ADDRESS=alerts@football-prediction.com

# ==================== 数据收集器配置 ====================
# Titan007 数据采集配置
TITAN_BASE_URL=https://live.titan007.com/api/odds
TITAN_MAX_RETRIES=3
TITAN_TIMEOUT=30.0
TITAN_MAX_CONNECTIONS=20
TITAN_MAX_KEEPALIVE_CONNECTIONS=10
TITAN_RATE_LIMIT_QPS=2.0
TITAN_RATE_LIMIT_BURST=1
TITAN_RATE_LIMIT_MAX_WAIT=30.0

# ==================== MLOps 配置 ====================
# 模型热重载配置
MODEL_RELOAD_ENABLED=true
MODEL_RELOAD_INTERVAL=3600  # 每小时检查一次

# 模型性能监控
MODEL_ACCURACY_THRESHOLD=0.60
MODEL_DRIFT_THRESHOLD=0.05

# ==================== 健康检查配置 ====================
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10