  "timing": {
    "pageWaitMs": 8000,
    "scrollDelayMs": 1000,
    "loadMoreDelayMs": 1500,
    "interMonthDelayMs": 3000,
    "maxScrollAttempts": 15
  },
  "selectors": {
    "cookieBanner": "button:has-text('Agree'), button:has-text('Accept'), button:has-text('OK'), [id*='cookie'] button",
    "loadMoreButton": "button:has-text('Show more')",
    "matchRow": "div[role='row'], tr, .eventRow, [data-testid*='match']",
    "homeTeam": ".home-team, .team-home, [data-testid*='home'], td:nth-child(2) div, td:nth-child(2) a",
    "awayTeam": ".away-team, .team-away, [data-testid*='away'], td:nth-child(4) div, td:nth-child(4) a",
    "score": ".score, .result, [data-testid*='score'], td:nth-child(3)",
    "date": ".date, .time, [data-testid*='date'], td:nth-child(1)",
    "matchLink": "a[href*='/football/']"
  },
  "database": {
    "table": "matches_oddsportal_mapping",
    "upsertConflictFields": ["odds_portal_match_id", "season", "home_team", "away_team"],
    "batchSize": 50
  },
  "matching": {
    "fuzzyThreshold": 0.75,
    "minTeamMatchScore": 0.5
  },
  "logging": {
    "component": "DOMSurgicalHarvest",
    "logLevel": "info",
    "enableDebug": false
  }
}
