# TITAN Football Prediction Platform - Environment Configuration
# Copy this file to .env and fill in your actual values
# =============================================================================

# =============================================================================
# Database Configuration
# =============================================================================
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=football_db
DB_USER=football_user
DB_PASSWORD=your_secure_password_here

# Database Connection Pool
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT=30000

# =============================================================================
# Data Paths (Relative to project root or absolute)
# =============================================================================
# Default: data/matches (relative to process.cwd())
DATA_MATCHES_PATH=data/matches

# Default: data/sessions
DATA_SESSIONS_PATH=data/sessions

# Default: data/debug
DATA_DEBUG_PATH=data/debug

# =============================================================================
# Harvester Configuration
# =============================================================================
# Number of concurrent workers
MAX_WORKERS=6

# Request delay range (milliseconds)
MIN_DELAY_MS=10000
MAX_DELAY_MS=15000

# Session rotation threshold (matches per session)
SESSION_ROTATION_THRESHOLD=20

# Batch size for harvesting
HARVEST_BATCH_SIZE=500

# =============================================================================
# Network & Proxy Configuration
# =============================================================================
# Proxy server configuration
# 留空时统一回退到 config/proxy_pool.json
PROXY_HOST=
PROXY_PORT=

# Disable proxy for local development
# DISABLE_PROXY=true

# =============================================================================
# Browser Configuration
# =============================================================================
# Playwright browser options
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=60000

# Stealth mode level (minimal|standard|aggressive)
STEALTH_LEVEL=minimal

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=info
LOG_FILE=logs/titan.log

# =============================================================================
# Feature Flags
# =============================================================================
# Dry run mode (no actual data save)
# DRY_RUN=true

# Serie A pilot mode (only harvest Serie A matches)
# SERIE_A_PILOT=true

# Enable verbose logging
# VERBOSE_LOGGING=true

# =============================================================================
# Session Configuration
# =============================================================================
# Default session file path (relative to project root)
DEFAULT_SESSION_PATH=manual_session.json

# Cookie refresh interval (minutes)
COOKIE_REFRESH_INTERVAL=30
