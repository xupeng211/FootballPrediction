{
  "_version": "V41.350",
  "_description": "Production harvester settings - The Great Consolidation",
  "_last_updated": "2026-01-21",

  "browser": {
    "headless": true,
    "disable_gpu": true,
    "proxy_port": 7892,
    "viewport": {
      "width": 1920,
      "height": 1080
    }
  },

  "concurrency": {
    "max_workers": 12,
    "batch_size": 20,
    "memory_limit_gb": 24
  },

  "golden_shield": {
    "feature_richness_threshold": 30,
    "require_xg": true,
    "require_shots": true,
    "require_possession": true,
    "require_attack_data": true,
    "quality_thresholds": {
      "excellent": 100,
      "good": 80,
      "fair": 50
    }
  },

  "database": {
    "pool_min": 2,
    "pool_max": 15,
    "pool_timeout": 10,
    "pool_recycle": 600
  },

  "harvest_limits": {
    "default_limit": 50,
    "max_retries": 3,
    "retry_delay_seconds": 5,
    "request_timeout_seconds": 30
  },

  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s: %(message)s"
  }
}
