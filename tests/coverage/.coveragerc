[run]
branch = True
source = src
omit =
    */tests/*
    */venv/*
    */env/*
    */__pycache__/*
    */migrations/*
    */conftest.py
    */scripts/docker-manager.sh
    */ci-verify.sh
    */Makefile
    *.toml
    *.yml
    *.yaml
    *.json
    *.md
    *.sh
    */config_secure.py
    */.env*

[report]
exclude_lines =
    # 没有被覆盖到的时候忽略的代码行类型
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
    .*# pragma: no cover
    .*# type: ignore
    .*# noqa:.*
    .*# flake8:.*

precision = 2
show_missing = True
skip_covered = False
sort = Cover

[html]
directory = htmlcov
skip_covered = False
show_contexts = True

[xml]
output = coverage.xml

[paths]
source =
    src
    */site-packages/src