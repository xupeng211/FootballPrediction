# ============================================================
# V174 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填写实际值
# cp env.example .env
# ============================================================

# ============================================================
# 数据库配置 (必须)
# ============================================================
DB_HOST=db
DB_PORT=5432
DB_NAME=football_db
DB_USER=football_user
DB_PASSWORD=your_secure_password_here

# ============================================================
# 收割器配置
# ============================================================

# Worker 数量 (默认: 1)
MAX_WORKERS=1

# 单场收割延时 (毫秒)
MIN_DELAY_MS=10000
MAX_DELAY_MS=15000

# 数据质量门禁 (字节)
MIN_SIZE_BYTES=5000

# 重试配置
MAX_RETRY_ATTEMPTS=3
BACKOFF_BASE=2

# ============================================================
# 代理配置
# ============================================================

# 代理服务器地址
PROXY_HOST=172.25.16.1

# 代理端口范围 (逗号分隔)
# PROXY_PORTS=7890,7891,7892,7893,7894,7895,7896,7897,7898,7899,7900,7901,7902,7903,7904,7905,7906,7907,7908,7909,7910,7911

# 启用代理轮换
ENABLE_PROXY_ROTATION=true

# ============================================================
# 熔断器配置
# ============================================================

# 熔断阈值 (连续失败次数)
CIRCUIT_BREAKER_THRESHOLD=5

# 深度静默冷却时间 (毫秒, 默认 30 分钟)
COOL_DOWN_DURATION_MS=1800000

# ============================================================
# 数据库连接池
# ============================================================

DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CONNECT_TIMEOUT=10000
DB_QUERY_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000

# ============================================================
# 日志配置
# ============================================================

LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=/app/logs

# ============================================================
# 浏览器配置
# ============================================================

# 无头模式 (true/false)
HEADLESS=true

# 浏览器配置文件路径
BROWSER_PROFILE_PATH=/app/data/browser_profile

# ============================================================
# Redis 配置 (可选)
# ============================================================

REDIS_PORT=6379
REDIS_HOST=redis

# ============================================================
# API 配置 (可选)
# ============================================================

API_PORT=8000
API_WORKERS=2

# ============================================================
# 项目路径 (Docker 内部)
# ============================================================

PROJECT_ROOT=/app
DATA_DIR=/app/data
