# 开发环境配置
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# 数据库配置 (开发环境)
DATABASE_URL=postgresql+asyncpg://football_user:football_pass@localhost:5432/football_prediction_dev
ASYNC_DATABASE_URL=postgresql+asyncpg://football_user:football_pass@localhost:5432/football_prediction_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_prediction_dev
DB_USER=football_user
DB_PASSWORD=football_pass

# Redis配置 (开发环境)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# 安全配置 (开发环境 - 使用弱密码)
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# 监控与可视化安全配置
GRAFANA_ADMIN_PASSWORD=dev-grafana-password

# 邮件服务配置 (开发环境)
SMTP_HOST=smtp.example.com:587
SMTP_USER=dev@example.com
SMTP_PASSWORD=dev-email-password
SMTP_FROM_ADDRESS=dev@example.com

# 外部服务配置
EXTERNAL_API_TIMEOUT=30
EXTERNAL_API_RETRIES=3

# 足球数据API配置
FOOTBALL_DATA_API_KEY=ed809154dc1f422da46a18d8961a98a0

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090

# 开发工具配置
HOT_RELOAD=true
AUTO_RESTART=true

# 代理配置 (开发环境)
PROXY_LIST=http://host.docker.internal:7890
HTTP_PROXY=http://host.docker.internal:7890
HTTPS_PROXY=http://host.docker.internal:7890
NO_PROXY=localhost,127.0.0.1,0.0.0.0

