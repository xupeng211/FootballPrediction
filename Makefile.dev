# Football Prediction System - 开发环境 Makefile
# 提供常用的开发任务快捷命令

.PHONY: help dev dev-db dev-all test lint format clean status logs

# 默认目标
.DEFAULT_GOAL := help

# 颜色定义
GREEN := \033[0;32m
BLUE := \033[0;34m
YELLOW := \033[1;33m
RED := \033[0;31m
NC := \033[0m

# 帮助信息
help: ## 显示帮助信息
	@echo "$(BLUE)Football Prediction System - 开发环境命令$(NC)"
	@echo ""
	@echo "$(GREEN)开发服务器:$(NC)"
	@echo "  make dev          启动开发服务器"
	@echo "  make dev-db       启动开发服务器 + 数据库管理工具"
	@echo "  make dev-all      启动开发服务器 + 所有管理工具"
	@echo ""
	@echo "$(GREEN)代码质量:$(NC)"
	@echo "  make format       格式化代码"
	@echo "  make lint         代码检查"
	@echo "  make typecheck    类型检查"
	@echo "  make test         运行测试"
	@echo "  make test-watch   监视文件变化并运行测试"
	@echo ""
	@echo "$(GREEN)环境管理:$(NC)"
	@echo "  make env          安装开发环境"
	@echo "  make clean        清理临时文件"
	@echo "  make status       查看服务状态"
	@echo "  make logs         查看开发日志"
	@echo "  make stop         停止所有开发服务"
	@echo ""
	@echo "$(GREEN)数据库:$(NC)"
	@echo "  make db-reset     重置开发数据库"
	@echo "  make db-migrate   运行数据库迁移"
	@echo "  make db-shell     进入数据库shell"

# 开发服务器
dev: ## 启动开发服务器
	@echo "$(BLUE)启动开发服务器...$(NC)"
	@./scripts/start_dev.sh

dev-db: ## 启动开发服务器 + 数据库管理工具
	@echo "$(BLUE)启动开发服务器和数据库管理工具...$(NC)"
	@./scripts/start_dev.sh --db

dev-all: ## 启动开发服务器 + 所有管理工具
	@echo "$(BLUE)启动完整开发环境...$(NC)"
	@./scripts/start_dev.sh --all

# 代码质量
format: ## 格式化代码
	@echo "$(BLUE)格式化Python代码...$(NC)"
	@source .venv/bin/activate && black src/ tests/ scripts/ || echo "$(RED)请先安装black: pip install black$(NC)"

lint: ## 代码检查
	@echo "$(BLUE)运行代码检查...$(NC)"
	@source .venv/bin/activate && flake8 src/ tests/ scripts/ || echo "$(RED)请先安装flake8: pip install flake8$(NC)"

typecheck: ## 类型检查
	@echo "$(BLUE)运行类型检查...$(NC)"
	@source .venv/bin/activate && mypy src/ || echo "$(RED)请先安装mypy: pip install mypy$(NC)"

test: ## 运行测试
	@echo "$(BLUE)运行测试套件...$(NC)"
	@source .venv/bin/activate && python -m pytest tests/ -v || echo "$(RED)请先安装pytest: pip install pytest$(NC)"

test-watch: ## 监视文件变化并运行测试
	@echo "$(BLUE)启动测试监视器...$(NC)"
	@source .venv/bin/activate && ptw --runner "python -m pytest tests/ -v" || echo "$(RED)请先安装pytest-watch: pip install pytest-watch$(NC)"

# 环境管理
env: ## 安装开发环境
	@echo "$(BLUE)设置开发环境...$(NC)"
	@if [ ! -d ".venv" ]; then \
		python3 -m venv .venv; \
		echo "$(GREEN)虚拟环境已创建$(NC)"; \
	fi
	@source .venv/bin/activate && pip install --upgrade pip
	@source .venv/bin/activate && pip install -r requirements.txt
	@source .venv/bin/activate && pip install -r requirements-dev.txt
	@echo "$(GREEN)开发环境安装完成$(NC)"

clean: ## 清理临时文件
	@echo "$(BLUE)清理临时文件...$(NC)"
	@find . -type f -name "*.pyc" -delete
	@find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
	@find . -type d -name "*.egg-info" -exec rm -rf {} + 2>/dev/null || true
	@rm -rf .pytest_cache/ .coverage htmlcov/
	@echo "$(GREEN)清理完成$(NC)"

# 服务管理
status: ## 查看服务状态
	@echo "$(BLUE)开发环境服务状态:$(NC)"
	@echo ""
	@echo "$(YELLOW)Python进程:$(NC)"
	@ps aux | grep uvicorn | grep -v grep || echo "  无运行中的开发服务器"
	@echo ""
	@echo "$(YELLOW)Docker容器:$(NC)"
	@docker ps --filter "name=football-dev-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" || echo "  无运行中的开发容器"

logs: ## 查看开发日志
	@echo "$(BLUE)开发服务器日志:$(NC)"
	@echo "$(YELLOW)按Ctrl+C退出日志查看$(NC)"
	@docker logs -f football-dev-db 2>/dev/null || echo "PostgreSQL日志不可用"

stop: ## 停止所有开发服务
	@echo "$(BLUE)停止开发服务...$(NC)"
	@pkill -f "uvicorn.*src.main" || true
	@docker stop football-dev-db football-dev-redis 2>/dev/null || true
	@docker rm football-dev-db football-dev-redis 2>/dev/null || true
	@echo "$(GREEN)所有开发服务已停止$(NC)"

# 数据库管理
db-reset: ## 重置开发数据库
	@echo "$(BLUE)重置开发数据库...$(NC)"
	@docker stop football-dev-db 2>/dev/null || true
	@docker rm football-dev-db 2>/dev/null || true
	@docker run -d --name football-dev-db \
		-e POSTGRES_DB=football_prediction_dev \
		-e POSTGRES_USER=football_user \
		-e POSTGRES_PASSWORD=football_pass \
		-p 5432:5432 \
		postgres:15
	@echo "$(GREEN)数据库已重置$(NC)"

db-migrate: ## 运行数据库迁移
	@echo "$(BLUE)运行数据库迁移...$(NC)"
	@source .venv/bin/activate && alembic upgrade head || echo "$(RED)迁移失败，请检查配置$(NC)"

db-shell: ## 进入数据库shell
	@echo "$(BLUE)连接到开发数据库...$(NC)"
	@docker exec -it football-dev-db psql -U football_user -d football_prediction_dev || echo "$(RED)数据库不可用$(NC)"

# 快捷命令
install-deps: ## 快捷命令：安装依赖
	@make env

run-tests: ## 快捷命令：运行测试
	@make test

check-quality: ## 快捷命令：检查代码质量
	@make format && make lint && make typecheck

start: ## 快捷命令：启动开发环境
	@make dev

restart: ## 重启开发环境
	@make stop && sleep 2 && make dev

# 开发提示
dev-tips: ## 开发技巧提示
	@echo "$(BLUE)开发环境使用技巧:$(NC)"
	@echo ""
	@echo "$(YELLOW)热重载:$(NC) 修改src/目录下的文件会自动重启服务器"
	@echo "$(YELLOW)调试:$(NC)   使用print()或logging模块进行调试"
	@echo "$(YELLOW)测试:$(NC)   运行 'make test-watch' 监视测试"
	@echo "$(YELLOW)环境变量:$(NC) 在.env.dev中配置"
	@echo "$(YELLOW)API文档:$(NC) 访问 http://localhost:8000/docs"
	@echo ""
	@echo "$(GREEN)常用端口:$(NC)"
	@echo "  • API服务:    8000"
	@echo "  • PostgreSQL: 5432"
	@echo "  • Redis:      6379"
	@echo "  • Adminer:    8080 (如果启用)"
	@echo "  • Redis CMD:  8081 (如果启用)"