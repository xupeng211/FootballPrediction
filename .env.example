# FootballPrediction V2.3.1 - Environment Configuration Template
# ROI +13.35% 盈利版 - 环境变量配置模板
#
# 使用方法:
# 1. 复制此文件: cp .env.example .env
# 2. 编辑 .env 文件，填入真实配置值
# 3. 确保 .env 文件已添加到 .gitignore 中

# ========================================
# 🏆 核心系统配置 (V2.3.1)
# ========================================
# 系统版本和运行模式
ENVIRONMENT=production
DOCKER_ENV=true
PYTHONPATH=/app
PYTHONUNBUFFERED=1
TZ=UTC

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/engine.log

# ========================================
# 🗄️ 数据库连接配置 (PostgreSQL 15)
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_prediction
DB_USER=football_user
DB_PASSWORD=your_secure_password_here
DB_SSL_MODE=prefer
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# ========================================
# 📦 Redis 缓存配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20
REDIS_CONNECTION_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_MAX_MEMORY=512mb
REDIS_EVICTION_POLICY=allkeys-lru

# ========================================
# 🌐 FotMob API 配置 (核心数据源)
# ========================================
# FotMob API 必需的请求头 - 从浏览器开发者工具获取
FOTMOB_X_MAS_HEADER=your_fotmob_x_mas_header_here
FOTMOB_BASE_URL=https://www.fotmob.com/api
FOTMOB_REQUEST_DELAY=1.0
FOTMOB_MAX_RETRIES=3
FOTMOB_TIMEOUT=30
FOTMOB_RATE_LIMIT_ENABLED=true

# ========================================
# 🤖 XGBoost 模型配置 (V2.3.1 预测核心)
# ========================================
MODEL_VERSION=v2.3.1_real_scores
MODEL_PATH=/app/data/models/xgb_football_v2_real_scores.joblib
MODEL_FEATURE_COUNT=106
MODEL_ACCURACY=0.60
MODEL_RESPONSE_TIME_MS=100

# 模型推理配置
MODEL_BATCH_SIZE=1
MODEL_THREAD_COUNT=4
MODEL_NORMALIZE_FEATURES=true
MODEL_FEATURE_SCALING=standard

# ========================================
# 💰 ROI 优化配置 (+13.35% 盈利策略)
# ========================================
# 最小预测边际 - 避免低价值预测
MIN_EDGE=7

# 最小置信度阈值 - 确保预测可靠性
MIN_CONFIDENCE=45

# 投注策略配置
KELLY_FRACTION=0.25
MAX_BET_PERCENTAGE=5.0
MIN_ODDS=1.5
MAX_ODDS=10.0

# ========================================
# 📊 数据收集配置
# ========================================
# 数据收集限制和调度
DATA_COLLECTION_LIMIT=700
DATA_COLLECTION_INTERVAL=3600
DATA_RETENTION_DAYS=365

# 特征提取配置
FEATURE_EXTRACTION_TIMEOUT=300
FEATURE_CACHE_TTL=1800
DYNAMIC_FEATURE_BACKFILL=true
HISTORICAL_MATCH_LIMIT=5

# ========================================
# 🚀 Web 服务配置 (FastAPI)
# ========================================
# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
API_ACCESS_LOG=true

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE"]
CORS_ALLOW_HEADERS=["*"]

# ========================================
# 🔍 监控和健康检查配置
# ========================================
# 健康检查配置
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# 性能监控
PERFORMANCE_MONITORING=true
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# 数据质量监控
DATA_QUALITY_CHECK_ENABLED=true
DATA_QUALITY_INTERVAL=300
DATA_QUALITY_THRESHOLD=0.95

# ========================================
# 🛡️ 安全配置
# ========================================
# API 安全
API_KEY_HEADER=X-API-Key
API_KEY=your_api_key_here
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# 请求限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# SSL/TLS 配置
SSL_ENABLED=false
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem

# ========================================
# 📈 机器学习实验配置
# ========================================
# MLflow 配置 (可选)
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=football_prediction_v2

# Optuna 超参数优化 (可选)
OPTUNA_ENABLED=false
OPTUNA_N_TRIALS=100
OPTUNA_TIMEOUT=3600

# ========================================
# 🔧 开发和调试配置
# ========================================
# 开发模式配置
DEBUG=false
DEBUG_SQL=false
DEBUG_API_REQUESTS=false
DEBUG_FEATURE_EXTRACTION=false

# 测试配置
TEST_DATABASE_URL=postgresql://football_user:test_password@localhost:5432/football_prediction_test
TEST_REDIS_URL=redis://localhost:6379/1
MOCK_EXTERNAL_APIS=true

# ========================================
# 📢 通知和告警配置
# ========================================
# 邮件通知 (可选)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com

# Slack 通知 (可选)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=your_slack_webhook_url
SLACK_CHANNEL=#alerts

# ========================================
# 🐳 Docker 特定配置
# ========================================
# Docker 容器配置
CONTAINER_NAME=footballprediction-engine
CONTAINER_RESTART_POLICY=unless-stopped
CONTAINER_MEMORY_LIMIT=2g
CONTAINER_CPU_LIMIT=2.0

# ========================================
# 📋 备份和恢复配置
# ========================================
# 数据库备份配置
BACKUP_ENABLED=false
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/app/backups

# 自动恢复配置
AUTO_RECOVERY_ENABLED=true
AUTO_RECOVERY_CHECK_INTERVAL=300
AUTO_RECOVERY_MAX_ATTEMPTS=3

# ========================================
# 🔮 未来扩展配置 (预留)
# ========================================
# 多语言支持
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,zh,es,fr,de

# 实时流处理
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_MATCHES=football_matches

# 分布式计算
RAY_ENABLED=false
RAY_ADDRESS=localhost:6379