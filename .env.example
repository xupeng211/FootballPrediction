# ============================================
# FootballPrediction - Environment Configuration
# ============================================
# Quantitative Data Acquisition Engine
# Production-ready template

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_db
DB_USER=football_user
DB_PASSWORD=your_secure_password_here

# Concurrency Settings
CONCURRENT_THREADS=10

# Browser Automation
HEADLESS_MODE=true

# V127.000: Stealth Mode Configuration
# Base wait time for jittered delays (milliseconds)
WAIT_BASE_MS=2000
# Random jitter range added to base wait (milliseconds)
WAIT_JITTER_MS=1500
# Timeout for cookie banner detection/handling (milliseconds)
COOKIE_BANNER_TIMEOUT=2000

# V129.000: Dynamic Proxy Discovery Configuration
# Enable proxy rotation for IP diversity (1-thread-1-IP)
ENABLE_PROXY_ROTATION=false
# Windows host IP (WSL2 gateway for Clash nodes)
PROXY_HOST=172.25.16.1
# Port range for auto-discovery (Clash狂暴模式: 23 nodes)
PROXY_PORT_START=7891
PROXY_PORT_END=7913
# Port scan timeout (milliseconds) - lower = faster discovery
PROXY_SCAN_TIMEOUT=500
# Proxy protocol (http/socks5)
PROXY_PROTOCOL=http

# V133.000: Ultimate Visual Breakthrough Configuration
# Timeout for waiting trajectory data packet signal (milliseconds)
SIGNAL_WAIT_TIMEOUT=15000
# Force physical removal of overlay DOM nodes (true = purge, false = click only)
FORCE_REMOVE_OVERLAYS=true

# V136.000: Precision Tuning Configuration
# Stabilization delay after hover to ensure DOM rendering completion (milliseconds)
HOVER_STABILIZE_MS=1500
# Retry count for modal trigger (pixel-shift retry if hover doesn't show modal)
MODAL_RETRY_COUNT=2
# Adaptive signal bypass timeout (milliseconds) - if .dat not found but odds visible, proceed
ADAPTIVE_SIGNAL_TIMEOUT=5000

# V138.000: Modular Strike Configuration
# Enable scrollIntoViewIfNeeded before hover operations (ensures element visibility)
SCROLL_INTO_VIEW_BEFORE_HOVER=true
# Enable enhanced telemetry dashboard with real-time metrics
TELEMETRY_DASHBOARD_ENABLED=true
# Telemetry report interval (number of matches between reports)
TELEMETRY_REPORT_INTERVAL=20

# V138.000: Golden Zone Filtering (2024-2026)
# Only harvest matches from this date onwards (ISO 8601 format)
# Set to 2024-01-01 to focus on high-yield golden zone
GOLDEN_ZONE_START_DATE=2024-01-01
# Disable date filtering (set to true to process all matches regardless of date)
GOLDEN_ZONE_FILTER_DISABLED=false

# V138.000: High-Concurrency Deployment (15-way parallel harvest)
# Maximum concurrent harvest operations (overwrites CONCURRENT_THREADS if set)
HARVEST_MAX_CONCURRENT=15
# Number of retry attempts for failed harvest operations
HARVEST_RETRY_ATTEMPTS=2
# Delay between retry attempts (milliseconds)
HARVEST_RETRY_DELAY_MS=5000

# V140.000: Data Purity - Timezone & Year Calibration
# Force UTC timezone for all timestamp parsing (prevents local timezone interference)
ENFORCE_UTC=true
# Base year for timestamp calibration (prevents future date parsing errors)
BASE_YEAR=2026
# Maximum future date tolerance (hours) - dates beyond this trigger year rollback
MAX_FUTURE_TOLERANCE_HOURS=48

# Optional: Environment Proxy Configuration (fallback)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
