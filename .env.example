# FootballPrediction - Environment Variables Template
# ===================================================
# Copy this file to .env and fill in the actual values.
# DO NOT commit .env to version control!

# --- Application ---
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-this-to-a-random-string-at-least-32-characters-long
APP_NAME=Football Prediction System
APP_VERSION=1.2.0

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_prediction
DB_USER=football_user
DB_PASSWORD=your_secure_password_here
DB_SSL_MODE=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password_here

# --- External APIs ---
FOTMOB_BASE_URL=https://www.fotmob.com/api
# FOTMOB_X_MAS_HEADER=
# FOTMOB_X_FOO_HEADER=

# --- Model ---
MODEL_PATH=models/v27_0_epl_ewma.pkl
MODEL_VERSION=xgboost_v2

# --- Monitoring ---
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false

# --- Cache ---
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# --- Business Logic ---
DEFAULT_CONFIDENCE_THRESHOLD=0.6
MIN_EDGE=7.0
MIN_CONFIDENCE=45.0
TARGET_ROI=13.35

# --- Pipeline ---
HARVEST_BATCH_SIZE=50
HARVEST_DELAY_SECONDS=1.0
MAX_L2_CONCURRENCY=2
PIPELINE_BATCH_SIZE=50
PIPELINE_GC_INTERVAL=50
