# ========================================
# Football Prediction v2.0 环境配置示例
# ========================================

# 应用基础配置
ENVIRONMENT=development
DEBUG=false
TZ=UTC
PYTHONPATH=/app/src

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_prediction_dev
DB_USER=football_user
DB_PASSWORD=football_pass

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# 模型配置
MODEL_PATH=/app/data/models
DEFAULT_MODEL_NAME=xgboost_v2
MODEL_VERSION=v2.0.0

# 外部 API 配置（生产环境必需）
FOTMOB_X_MAS_HEADER=your_fotmob_mas_header
FOTMOB_X_FOO_HEADER=your_fotmob_foo_header

# 功能开关
ENABLE_METRICS=true
ENABLE_CELERY=true
ENABLE_DEBUG=false
ENABLE_PRODUCTION_LOGGING=false

# 监控配置
PROMETHEUS_METRICS_PATH=/metrics
METRICS_SCRAPE_INTERVAL=15s

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# 安全配置
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# v2.0 服务配置
INFERENCE_SERVICE_V2_ENABLED=true
COLLECTION_SERVICE_ENABLED=true
EXPLAINABILITY_SERVICE_ENABLED=true

# 性能配置
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_CONNECTIONS=100

# 测试配置
TEST_DB_NAME=football_prediction_test
TEST_REDIS_DB=1