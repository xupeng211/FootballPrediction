# FootballPrediction - Environment Variables Template
# ===================================================
# Version: V139.1
# Copy this file to .env and fill in the actual values.
# DO NOT commit .env to version control!

# ===================================================================
# APPLICATION SETTINGS
# ===================================================================
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-this-to-a-random-string-at-least-32-characters-long
APP_NAME=Football Prediction System
APP_VERSION=V139.1
DOCKER_ENV=false

# --- Server ---
HOST=0.0.0.0
PORT=8000
API_PORT=8000
WORKERS=1

# ===================================================================
# DATABASE (PostgreSQL 15)
# ===================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_db
DB_USER=football_user
DB_PASSWORD=your_secure_password_here
DB_SSL_MODE=false

# Docker environments use 'db' as hostname
# DB_HOST=db

# ===================================================================
# REDIS (Redis 7)
# ===================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# REDIS_PASSWORD=your_redis_password_here

# Docker environments use 'redis' as hostname
# REDIS_HOST=redis

# ===================================================================
# EXTERNAL APIs
# ===================================================================

# --- FotMob API ---
FOTMOB_BASE_URL=https://www.fotmob.com/api
# FOTMOB_X_MAS_HEADER=
# FOTMOB_X_FOO_HEADER=

# --- OddsPortal ---
ODDSPORTAL_BASE_URL=https://www.oddsportal.com
ODDSPORTAL_TIMEOUT_MS=60000

# ===================================================================
# MODEL SETTINGS
# ===================================================================
MODEL_PATH=model_zoo/v26.8_epl_production.pkl
MODEL_VERSION=xgboost_v26.8
MODEL_ZOO_PATH=model_zoo/

# ===================================================================
# MONITORING & METRICS
# ===================================================================
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# ===================================================================
# CACHE SETTINGS
# ===================================================================
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# ===================================================================
# BUSINESS LOGIC
# ===================================================================
DEFAULT_CONFIDENCE_THRESHOLD=0.6
MIN_EDGE=7.0
MIN_CONFIDENCE=45.0
TARGET_ROI=13.35

# ===================================================================
# PIPELINE SETTINGS
# ===================================================================
HARVEST_BATCH_SIZE=50
HARVEST_DELAY_SECONDS=1.0
MAX_L2_CONCURRENCY=2
PIPELINE_BATCH_SIZE=50
PIPELINE_GC_INTERVAL=50

# ===================================================================
# V56.0 Production Harvester Configuration
# ===================================================================

# Batch processing (anti-ban mechanism)
HARVESTER_BATCH_INTERVAL=30
HARVESTER_BATCH_REST_SECONDS=60

# IP health monitoring
HARVESTER_CONNECTION_ERROR_THRESHOLD=3
HARVESTER_CONNECTION_COOLDOWN_SECONDS=300

# Page load timeouts
HARVESTER_GOTO_TIMEOUT_MS=90000
HARVESTER_WAIT_AFTER_LOAD_MS=20000

# Target entities for extraction
HARVESTER_TARGET_ENTITIES=Entity_P,Entity_B3

# Progress reporting
HARVESTER_PROGRESS_REPORT_INTERVAL=10

# ===================================================================
# V138.0+ URL Harvest Configuration
# ===================================================================

# URL Search Concurrency (L2 Layer)
URL_SEARCH_CONCURRENCY=4
URL_SEARCH_TIMEOUT_MS=30000
URL_SEARCH_RETRY_ATTEMPTS=3

# URL Format Validation (Critical: Only new format supported)
URL_FORMAT_VALIDATE=true
URL_ALLOW_NEW_FORMAT=true
URL_ALLOW_LEGACY_FORMAT=false

# ===================================================================
# V139.0 Auto Cruise Controller Configuration
# ===================================================================

# Navigation Settings
CRUISE_NAVIGATION_DELAY_MS=2000
CRUISE_SCROLL_ATTEMPTS=3
CRUISE_WAIT_FOR_SELECTOR_TIMEOUT_MS=60000

# Extraction Settings
CRUISE_EXTRACT_CONCURRENCY=2
CRUISE_HOVER_RETRY_ATTEMPTS=10
CRUISE_HOVER_RETRY_DELAY_MS=500

# Data Integrity
CRUISE_INTEGRITY_SCORE_MIN=1.02
CRUISE_INTEGRITY_SCORE_MAX=1.08
CRUISE_VALIDATE_PROBABILITIES=true

# ===================================================================
# LOGGING
# ===================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_ERROR_FILE_PATH=logs/error.log
LOG_ROTATION=true
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ===================================================================
# PLAYWRIGHT BROWSER SETTINGS
# ===================================================================

# Browser Selection
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_HEADLESS=true

# Stealth Mode
PLAYWRIGHT_STEALTH_ENABLED=true
PLAYWRIGHT_STEALTH_CONFIG=config/stealth.json

# Viewport Configuration
PLAYWRIGHT_VIEWPORT_WIDTH=1920
PLAYWRIGHT_VIEWPORT_HEIGHT=1080

# User-Agent Randomization
PLAYWRIGHT_RANDOM_UA=true

# Page Load Strategy
PLAYWRIGHT_WAIT_UNTIL=networkidle
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=90000

# ===================================================================
# SECURITY
# ===================================================================

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ===================================================================
# DEVELOPMENT SETTINGS
# ===================================================================

# Testing
TEST_DB_NAME=football_test_db
TEST_REDIS_DB=1

# Debugging
DEBUGPY_ENABLE=false
DEBUGPY_PORT=5678

# Profiling
PROFILING_ENABLED=false
PROFILING_OUTPUT_DIR=logs/profiling

# ===================================================================
# DEPLOYMENT SETTINGS
# ===================================================================

# Deployment Type (development/staging/production)
DEPLOYMENT_TYPE=development

# Health Check
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10
HEALTH_CHECK_RETRIES=3

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30

# ===================================================================
# FEATURE FLAGS
# ===================================================================

FEATURE_ENABLE_PREDICTION_ENDPOINT=true
FEATURE_ENABLE_ADMIN_ENDPOINT=false
FEATURE_ENABLE_BATCH_PROCESSING=true
FEATURE_ENABLE_AUTO_CRUISE=true
FEATURE_ENABLE_RPA_EXTRACTION=true

# ===================================================================
# BACKUP & MAINTENANCE
# ===================================================================

# Database Backup
BACKUP_ENABLED=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=backups/

# Log Cleanup
LOG_CLEANUP_ENABLED=true
LOG_CLEANUP_DAYS=7
LOG_CLEANUP_INTERVAL_HOURS=24

# ===================================================================
# END OF CONFIGURATION
# ===================================================================
# Last Updated: 2026-01-05
# Version: V139.1
