# ============================================
# FootballPrediction V29.0 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填写实际值
# 生成时间: 2025-12-25
# 版本: V29.0 Production
# ============================================

# ============================================
# 应用配置
# ============================================
ENVIRONMENT=production
LOG_LEVEL=INFO
TZ=UTC
SECRET_KEY=change-this-to-a-random-string-at-least-32-characters-long

# ============================================
# 数据库配置
# ============================================
DB_HOST=db
DB_PORT=5432
DB_NAME=football_db
DB_USER=football_user
DB_PASSWORD=your-secure-password-here

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# V25.0 流水线配置
# ============================================
PIPELINE_MODE=loop
BATCH_SIZE=50
HEARTBEAT_INTERVAL=1800

# ============================================
# 模型配置
# ============================================
MODEL_VERSION=v24.1
FEATURE_DIMENSION=3002
DEFAULT_CONFIDENCE_THRESHOLD=0.55

# ============================================
# API 配置
# ============================================
API_PORT=8000
API_WORKERS=2

# ============================================
# 风控配置
# ============================================
MAX_POSITION_SIZE=0.05
MAX_DAILY_EXPOSURE=0.10
STOP_LOSS_THRESHOLD=-0.15
