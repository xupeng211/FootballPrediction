# ============================================
# FootballPrediction V171 - 环境配置模板
# ============================================
#
# 使用方法:
#   1. 复制此文件为 .env
#   2. 填入真实配置值
#   3. 确保 .env 不会被提交到 Git
#
# ============================================

# ============================================
# 数据库配置 (必填)
# ============================================

# 数据库主机地址
# - 本地开发: localhost
# - Docker: db
DB_HOST=localhost

# 数据库端口
DB_PORT=5432

# 数据库名称
DB_NAME=football_db

# 数据库用户名
DB_USER=football_user

# 数据库密码 [必填]
# ⚠️ 生产环境必须设置强密码
DB_PASSWORD=your_secure_password_here

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARN, ERROR, CRITICAL
LOG_LEVEL=info

# 日志目录
LOG_DIR=./logs

# ============================================
# 代理配置 (NetworkShield)
# ============================================

# 启用代理轮换 (true/false)
# - 开发环境: false
# - 生产环境: true
ENABLE_PROXY_ROTATION=false

# 代理主机地址
# - Windows/WSL2: Clash Verge 网关地址
PROXY_HOST=172.25.16.1

# 代理端口范围
# - Clash 狂暴模式: 7891-7912 (22 节点)
PROXY_PORT_START=7891
PROXY_PORT_END=7912

# 代理协议: http, socks5
PROXY_PROTOCOL=http

# 端口扫描超时 (毫秒)
PROXY_SCAN_TIMEOUT=500

# ============================================
# 浏览器自动化配置
# ============================================

# 无头模式 (true/false)
# - 服务器: true
# - 调试: false
HEADLESS_MODE=true

# 并发线程数
CONCURRENT_THREADS=10

# ============================================
# V127+ 等待配置
# ============================================

# 基础等待时间 (毫秒)
WAIT_BASE_MS=2000

# 随机抖动范围 (毫秒)
WAIT_JITTER_MS=1500

# Cookie 横幅检测超时 (毫秒)
COOKIE_BANNER_TIMEOUT=2000

# ============================================
# V133+ 视觉突破配置
# ============================================

# 轨迹数据信号等待超时 (毫秒)
SIGNAL_WAIT_TIMEOUT=15000

# 强制移除覆盖层 (true/false)
FORCE_REMOVE_OVERLAYS=true

# ============================================
# V136+ 精确调优配置
# ============================================

# 悬停稳定延迟 (毫秒)
HOVER_STABILIZE_MS=1500

# 模态触发重试次数
MODAL_RETRY_COUNT=2

# 自适应信号超时 (毫秒)
ADAPTIVE_SIGNAL_TIMEOUT=5000

# ============================================
# V171 收割配置
# ============================================

# 批量收割限制
HARVEST_LIMIT=50

# 调度器检查间隔 (分钟)
SCHEDULER_INTERVAL=60

# 预测置信度阈值
PREDICTION_THRESHOLD=0.65

# SSR 信号阈值 (0.0-1.0)
SSR_THRESHOLD=0.80

# ============================================
# V172 数据收割引擎配置
# ============================================

# 项目根目录 (自动检测，通常无需设置)
PROJECT_ROOT=

# Worker 数量 (1-10)
MAX_WORKERS=5

# 单场延时范围 (毫秒)
MIN_DELAY_MS=5000
MAX_DELAY_MS=12000

# 质量门禁阈值 (字节)
MIN_SIZE_BYTES=5000

# 最大重试次数
MAX_RETRY_ATTEMPTS=3

# 熔断阈值 (连续失败次数)
CIRCUIT_BREAKER_THRESHOLD=3

# Worker 重启延迟 (毫秒)
WORKER_RESTART_DELAY_MS=30000

# Cookie 保存间隔 (每 N 场)
COOKIE_SAVE_INTERVAL=3

# 代理端口池 (逗号分隔)
PROXY_PORTS=7890,7891,7892,7893,7894

# 浏览器配置文件路径
BROWSER_PROFILE_PATH=/app/data/browser_profile

# 数据库连接超时 (毫秒)
DB_CONNECT_TIMEOUT=10000

# 数据库查询超时 (毫秒)
DB_QUERY_TIMEOUT=30000

# ============================================
# 安全配置
# ============================================

# 环境: development, staging, production
NODE_ENV=development

# 加密密钥 (可选)
# SECRET_KEY=your_secret_key_here
