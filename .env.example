# ============================================================================
# Football Prediction System - Environment Configuration Template
# ============================================================================
# IMPORTANT: Copy this file to .env and NEVER commit .env to version control
# This file contains all required environment variables for production deployment

# ============================================================================
# Application Configuration
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development
DEBUG=false
TZ=UTC
PYTHONPATH=/app/src

# Security - MUST be changed in production!
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_32_CHARS_MINIMUM
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_32_CHARS_MINIMUM_DIFFERENT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# API Service Configuration
API_HOST=127.0.0.1
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_prediction_dev
DB_USER=football_user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_SSL_MODE=prefer

# Connection Pool Configuration
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_POOL_MAX_QUERIES=50000
DB_POOL_MAX_INACTIVE_LIFETIME=300.0
DB_COMMAND_TIMEOUT=30.0
DB_HEALTH_CHECK_INTERVAL=30.0
DB_HEALTH_CHECK_TIMEOUT=5.0
DB_MAX_RETRIES=3

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_CONNECTION_TIMEOUT=5.0

# ============================================================================
# FotMob API Configuration (CRITICAL - Must be configured for production)
# ============================================================================
# Obtain these values from FotMob API documentation or your API provider
FOTMOB_BASE_URL=https://www.fotmob.com/api
FOTMOB_X_MAS_HEADER=CHANGE_ME_IN_PRODUCTION
FOTMOB_X_FOO_HEADER=CHANGE_ME_IN_PRODUCTION

# API Request Configuration
FOTMOB_MAX_RETRIES=3
FOTMOB_TIMEOUT=30
FOTMOB_DELAY_BETWEEN_REQUESTS=2.0
FOTMOB_MAX_CONCURRENT_REQUESTS=10

# ============================================================================
# Machine Learning Configuration
# ============================================================================
# Directories (all paths should be configurable)
DATA_DIR=/app/data
MODEL_DIR=/app/data/models
LOG_DIR=/app/logs
CACHE_DIR=/app/cache
MODEL_PATH=/app/data/models
DEFAULT_MODEL_NAME=xgboost_v2
MODEL_VERSION=v2.0.0

# Inference Configuration
ML_INFERENCE_TIMEOUT=5.0
ML_FEATURE_CACHE_TTL=3600
ML_BATCH_SIZE=100
ML_MAX_FEATURE_VECTOR_SIZE=1000

# ============================================================================
# Security Configuration
# ============================================================================
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Content Security Policy
CSP_DEFAULT_SRC="'self'"
CSP_SCRIPT_SRC="'self' 'unsafe-inline'"
CSP_STYLE_SRC="'self' 'unsafe-inline'"

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=200

# ============================================================================
# Monitoring Configuration
# ============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics
METRICS_COLLECTION_INTERVAL=60.0
HEALTH_CHECK_INTERVAL=30.0

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5
ENABLE_SQL_LOGGING=false

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_METRICS=true
ENABLE_CELERY=true
ENABLE_DEBUG=false
ENABLE_PRODUCTION_LOGGING=false
ENABLE_PERFORMANCE_PROFILING=false

# v2.0 Service Configuration
INFERENCE_SERVICE_V2_ENABLED=true
COLLECTION_SERVICE_ENABLED=true
EXPLAINABILITY_SERVICE_ENABLED=true

# ML Feature Flags
ENABLE_ADVANCED_FEATURES=true
ENABLE_H2H_FEATURES=true
ENABLE_VENUE_FEATURES=true
ENABLE_CACHE_MANAGER=true
ENABLE_BATCH_PREDICTIONS=true

# ============================================================================
# Performance Configuration
# ============================================================================
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_CONNECTIONS=100
KEEP_ALIVE_TIMEOUT=2

# Async Configuration
ASYNC_POOL_SIZE=20
ASYNC_MAX_OVERFLOW=30

# ============================================================================
# Testing Configuration
# ============================================================================
TEST_DB_NAME=football_prediction_test
TEST_REDIS_DB=1
TEST_API_PORT=8001

# ============================================================================
# External Services (Optional)
# ============================================================================
# Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Logging Services
LOGGLY_TOKEN=your-loggly-token
DATADOG_API_KEY=your-datadog-api-key

# ============================================================================
# Backup and Maintenance
# ============================================================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
AUTO_MIGRATION_ENABLED=true
CLEANUP_TEMP_FILES=true
CLEANUP_INTERVAL_HOURS=24

# ============================================================================
# Kelly Criterion Safety Controls (Production Ready)
# ============================================================================
# Risk Management Settings
KELLY_MAX_STAKE_PERCENTAGE=0.05              # 单笔最大投注比例 (5%)
KELLY_MAX_DAILY_STAKE_PERCENTAGE=0.20        # 日最大投注比例 (20%)
KELLY_EMERGENCY_STOP=true                    # 紧急停止开关
KELLY_MANUAL_OVERRIDE=false                  # 人工覆盖要求
KELLY_RISK_ALERT_THRESHOLD=0.03             # 风险告警阈值 (3%)

# Safety Validation
KELLY_SAFETY_ENABLED=true                    # 安全控制启用状态
KELLY_AUDIT_LOG=true                         # 审计日志
KELLY_MAX_CONCURRENT_BETS=5                  # 最大并发投注数
KELLY_DRAWDOWN_LIMIT=0.20                    # 最大回撤限制 (20%)

# 功能开关
ENABLE_METRICS=true
ENABLE_CELERY=true
ENABLE_DEBUG=false
ENABLE_PRODUCTION_LOGGING=false

# 监控配置
PROMETHEUS_METRICS_PATH=/metrics
METRICS_SCRAPE_INTERVAL=15s

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# 安全配置
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# v2.0 服务配置
INFERENCE_SERVICE_V2_ENABLED=true
COLLECTION_SERVICE_ENABLED=true
EXPLAINABILITY_SERVICE_ENABLED=true

# 性能配置
MAX_WORKERS=4
REQUEST_TIMEOUT=30
MAX_CONNECTIONS=100

# 测试配置
TEST_DB_NAME=football_prediction_test
TEST_REDIS_DB=1