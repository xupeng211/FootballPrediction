# ============================================
# FootballPrediction V173 - 环境配置模板
# ============================================
#
# 使用方法:
#   1. 复制此文件为 .env
#   2. 填入真实配置值
#   3. 确保 .env 不会被提交到 Git
#
# ============================================

# ============================================
# 数据库配置 (必填)
# ============================================

# 数据库主机地址
# - 宿主机 / WSL2 Mirrored / Docker 容器: 127.0.0.1
DB_HOST=127.0.0.1

# 数据库端口
DB_PORT=5432

# 数据库名称
DB_NAME=football_db

# 数据库用户名
DB_USER=football_user

# 数据库密码 [必填]
# ⚠️ 生产环境必须设置强密码
DB_PASSWORD=your_secure_password_here

# 数据库连接池配置
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000

# ============================================
# SC-002 DB Role Model — Dev POC role-specific connections
# ============================================
# WARNING: DEV-ONLY. All passwords are dev placeholders. Not for production.
# See deploy/docker/init_db.sql and docs/SC002_RUNTIME_DB_ROLE_PERMISSION_REVIEW_PHASE1.md
#
# Roles:
#   football_owner — DDL/migration owner (full privileges)
#   football_app   — runtime DML (SELECT, INSERT, UPDATE; no DDL)
#   football_ingestion — write-limited (INSERT, UPDATE on matches/raw_match_data/odds)
#   football_training  — training tables (INSERT, UPDATE on match_features_training/predictions)
#   football_reader — SELECT only (MCP, health checks, dashboards, audits)
#   football_gatekeeper — SELECT only (CI/test temporary probes)
#
# In production, all passwords MUST come from a secrets manager.

# DB Owner (DDL/migration)
DB_OWNER_USER=football_owner
DB_OWNER_PASSWORD=your_secure_password_here

# DB App (runtime DML)
DB_APP_USER=football_app
DB_APP_PASSWORD=your_secure_password_here

# DB Ingestion (limited write)
DB_INGESTION_USER=football_ingestion
DB_INGESTION_PASSWORD=your_secure_password_here

# DB Training (training/predictions tables)
DB_TRAINING_USER=football_training
DB_TRAINING_PASSWORD=your_secure_password_here

# DB Reader (SELECT only)
DB_READER_USER=football_reader
DB_READER_PASSWORD=your_secure_password_here

# DB Gatekeeper (CI/test temporary probes)
DB_GATEKEEPER_USER=football_gatekeeper
DB_GATEKEEPER_PASSWORD=your_secure_password_here

# ============================================
# 日志配置
# ============================================

# 日志级别: DEBUG, INFO, WARN, ERROR, CRITICAL
LOG_LEVEL=info

# 日志目录
LOG_DIR=./logs

# 日志文件配置
LOG_TO_FILE=false
LOG_MAX_SIZE=10485760
LOG_RETENTION_DAYS=7

# ============================================
# V6.0 22端口代理池配置 (NetworkShield + ProxyRotator)
# ============================================

# 启用代理轮换 (true/false)
# - 开发环境: false
# - 生产环境: true
ENABLE_PROXY_ROTATION=false

# 代理主机地址
# - WSL2 Mirrored / Docker: 127.0.0.1
PROXY_HOST=127.0.0.1

# V7.0 专用: 40端口物理隔离代理池配置
# 端口范围: 10001 - 10040 (共40个端口，1 Worker 绑定 1 端口)
# 策略: WSL2 Mirrored + SOCKS5 + Playwright 原生浏览器并发
PROXY_PORT_START=10001
PROXY_PORT_END=10040

# 完整代理端口列表 (逗号分隔)
PROXY_PORTS=10001,10002,10003,10004,10005,10006,10007,10008,10009,10010,10011,10012,10013,10014,10015,10016,10017,10018,10019,10020,10021,10022,10023,10024,10025,10026,10027,10028,10029,10030,10031,10032,10033,10034,10035,10036,10037,10038,10039,10040

# 代理协议: http, socks5
PROXY_PROTOCOL=socks5

# 端口扫描超时 (毫秒)
PROXY_SCAN_TIMEOUT=500

# 代理冷却时间 (毫秒，默认5分钟)
PROXY_COOLDOWN_MS=300000

# 健康检查间隔 (每N场比赛)
PROXY_HEALTH_CHECK_INTERVAL=100

# ============================================
# 浏览器自动化配置
# ============================================

# 无头模式 (true/false)
# - 服务器: true
# - 调试: false
HEADLESS=true

# 并发线程数
CONCURRENT_THREADS=10

# ============================================
# V127+ 等待配置
# ============================================

# 基础等待时间 (毫秒)
WAIT_BASE_MS=2000

# 随机抖动范围 (毫秒)
WAIT_JITTER_MS=1500

# Cookie 横幅检测超时 (毫秒)
COOKIE_BANNER_TIMEOUT=2000

# ============================================
# V133+ 视觉突破配置
# ============================================

# 轨迹数据信号等待超时 (毫秒)
SIGNAL_WAIT_TIMEOUT=15000

# 强制移除覆盖层 (true/false)
FORCE_REMOVE_OVERLAYS=true

# ============================================
# V136+ 精确调优配置
# ============================================

# 悬停稳定延迟 (毫秒)
HOVER_STABILIZE_MS=1500

# 模态触发重试次数
MODAL_RETRY_COUNT=2

# 自适应信号超时 (毫秒)
ADAPTIVE_SIGNAL_TIMEOUT=5000

# ============================================
# V171 收割配置
# ============================================

# 批量收割限制
HARVEST_LIMIT=50

# 调度器检查间隔 (分钟)
SCHEDULER_INTERVAL=60

# 预测置信度阈值
PREDICTION_THRESHOLD=0.65

# SSR 信号阈值 (0.0-1.0)
SSR_THRESHOLD=0.80

# ============================================
# V172/V173 数据收割引擎配置
# ============================================

# 项目根目录 (自动检测，通常无需设置)
PROJECT_ROOT=

# 数据目录
DATA_DIR=/app/data

# Worker 数量 (1-22)
MAX_WORKERS=5

# 批次大小
BATCH_SIZE=50

# Worker 错峰启动间隔 (毫秒)
STAGGER_START_MS=5000

# 监控检查间隔 (毫秒)
MONITOR_INTERVAL_MS=1000

# 单场延时范围 (毫秒)
MIN_DELAY_MS=5000
MAX_DELAY_MS=12000

# API 和页面超时配置
API_TIMEOUT=30000
PAGE_TIMEOUT=60000

# 质量门禁阈值 (字节)
MIN_SIZE_BYTES=5000
MAX_SIZE_BYTES=10485760

# 重试配置
MAX_RETRY_ATTEMPTS=3
BACKOFF_BASE=2
MAX_BACKOFF_MS=60000

# 熔断配置
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_COOLDOWN=60000
WORKER_RESTART_DELAY_MS=30000

# Cookie 保存间隔 (每 N 场)
COOKIE_SAVE_INTERVAL=3

# 代理端口池 (逗号分隔，支持 22 个端口)
PROXY_PORT=10001
PROXY_PORTS=10001,10002,10003,10004,10005,10006,10007,10008,10009,10010,10011,10012,10013,10014,10015,10016,10017,10018,10019,10020,10021,10022,10023,10024,10025,10026,10027,10028,10029,10030,10031,10032,10033,10034,10035,10036,10037,10038,10039,10040
PROXY_SERVER=socks5://127.0.0.1:{port}
PROXY_HEALTH_TIMEOUT=10000

# 浏览器配置文件路径
BROWSER_PROFILE_PATH=/app/data/browser_profile

# 数据库连接配置
DB_CONNECT_TIMEOUT=10000
DB_QUERY_TIMEOUT=30000

# ============================================
# V4.52+ 模块化架构配置
# ============================================

# Dispatcher 配置
DISPATCHER_MAX_WORKERS=6
DISPATCHER_BATCH_SIZE=500

# Persistence 配置
DATA_MATCHES_PATH=data/matches
PERSISTENCE_ENABLE_DUAL_SAVE=true

# ErrorHandler 配置
ERROR_HANDLER_MAX_RETRIES=3
ERROR_HANDLER_VERBOSE=false

# ============================================
# V173 深度静默模式配置
# ============================================

# 启用深度静默模式 (true/false)
ENABLE_COOL_DOWN=true

# 触发冷却的连续失败次数
COOL_DOWN_THRESHOLD=3

# 冷却时间 (毫秒，默认 30 分钟)
COOL_DOWN_DURATION_MS=1800000

# Cookie 最大年龄 (毫秒，默认 24 小时)
COOKIE_MAX_AGE_MS=86400000

# ============================================
# 哨兵监控配置
# ============================================

# 最大失败率阈值
MAX_FAILURE_RATE=0.10

# 最大连续 403 错误次数
MAX_CONSECUTIVE_403=5

# 健康报告路径
HEALTH_REPORT_PATH=/app/logs/factory_health.json

# 告警邮件 (可选)
ALERT_EMAIL=

# ============================================
# 增量模式配置
# ============================================

# 回溯天数
INCREMENTAL_LOOKBACK_DAYS=7

# 排除的联赛 (逗号分隔)
EXCLUDED_LEAGUES=

# ============================================
# 安全配置
# ============================================

# 环境: development, staging, production
NODE_ENV=development

# 加密密钥 (可选)
# SECRET_KEY=your_secret_key_here

# ============================================
# V6.6 L2 引擎配置 (TITAN MARATHON)
# ============================================

# 静默模式 (生产环境推荐开启)
# - true: 仅输出核心看板数据，减少磁盘 I/O
# - false: 输出详细调试信息
SILENT_MODE=true

# 调试模式: 使用原生 HTTP 而非 Stealth 浏览器
# - 设置此变量将禁用 Playwright，使用原生 HTTPS 请求
# - 仅用于调试网络问题
# DEBUG_RAW_HTTP=true

# 截图功能 (生产环境推荐关闭)
# - true: 允许截图 (仅严重错误时)
# - false: 完全禁用截图
ENABLE_SCREENSHOT=false

# 马拉松收割配置
MARATHON_WORKERS=22
MARATHON_STAGGER_MS=800
MARATHON_RESTART_THRESHOLD=500
MARATHON_MAX_ROUNDS=5

# 数据哨兵配置 (最小数据大小阈值，字节)
DATA_SENTINEL_MIN_SIZE=5120

# ============================================
# V11.0 Recon 侦察引擎配置
# ============================================

# ReconNavigator 配置
RECON_HEADLESS=true
RECON_SCROLL_ATTEMPTS=10
RECON_SCROLL_DELAY_MS=2000

# ReconResilience 熔断配置
RECON_CIRCUIT_THRESHOLD=5
RECON_CIRCUIT_RESET_MS=60000

# ReconDecryptor 配置
RECON_DECRYPT_TIMEOUT=30000

# DOM Surgical Harvest 配置
DOM_SURGICAL_CONFIG_PATH=config/dom_surgical_config.json
DOM_SURGICAL_HEADLESS=true

# TraceID 配置 (启用全链路追踪)
ENABLE_TRACE_ID=true
TRACE_ID_PREFIX=recon

# ============================================
# Docker Compose local defaults
# ============================================
#
# These values are safe local-development defaults used by docker-compose.yml
# and docker-compose.dev.yml. Copy this file to .env before running compose:
#
#   cp .env.example .env
#   docker compose config
#
# Do not commit .env.

COMPOSE_PROJECT_NAME=footballprediction
TZ=Asia/Shanghai

# Service ports
API_PORT=8000
DASHBOARD_PORT=3000
DEBUG_PORT=5678
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
PGADMIN_PORT=5050
REDIS_CMD_PORT=8081

# API / admin defaults for local development only
API_WORKERS=2
PGADMIN_EMAIL=admin@football.local
PGADMIN_PASSWORD=admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Backup / odds service defaults
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
ODDS_SCRAPER_SCHEDULE=0 */4 * * *
ODDS_SOURCE=oddsportal
ODDS_BATCH_SIZE=50
ODDS_DELAY_MIN=2
ODDS_DELAY_MAX=5

# Optional proxy values. Leave empty unless your machine requires a proxy.
HTTP_PROXY=
HTTPS_PROXY=

# Dev container proxy defaults. Override if your local proxy uses a different
# host or port.
DEV_HTTP_PROXY=http://host.docker.internal:7897
DEV_HTTPS_PROXY=http://host.docker.internal:7897
DEV_HOST_PROXY_PORT=7897
DEV_PROXY_HOST=host.docker.internal
DEV_PROXY_PORT=7897
DEV_PROXY_PORTS=7897
DEV_NO_PROXY=localhost,127.0.0.1,::1,db,redis,prometheus,grafana,host.docker.internal,mirrors.aliyun.com,registry.npmmirror.com,deb.nodesource.com,npmmirror.com

# Model artifacts are not committed to Git after repo slimming.
# Keep this path local and restore artifacts through the manifest/checker flow.
MODEL_ARTIFACT_DIR=./models
