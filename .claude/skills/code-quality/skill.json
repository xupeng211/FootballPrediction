{
  "name": "code-quality",
  "description": "FootballPrediction项目专门的代码质量管理技能",
  "version": "1.0.0",
  "category": "development",
  "enabled": true,
  "priority": "high",

  "triggers": [
    "代码质量检查",
    "代码格式化",
    "测试运行",
    "代码审查",
    "CI/CD流水线",
    "错误修复",
    "性能优化",
    "安全扫描"
  ],

  "capabilities": [
    "自动化代码质量检查",
    "测试执行和覆盖率分析",
    "代码格式化和修复",
    "复杂度和安全分析",
    "CI/CD集成",
    "项目特定的架构验证"
  ],

  "tools_integrated": [
    "black",
    "flake8",
    "mypy",
    "bandit",
    "radon",
    "vulture",
    "coverage",
    "pytest",
    "pre-commit"
  ],

  "project_specific": {
    "name": "FootballPrediction",
    "version": "v2.0.0",
    "architecture": "Service Layer v2.0 + ML Inference + Docker",
    "primary_language": "Python",
    "frameworks": ["FastAPI", "XGBoost", "Docker", "PostgreSQL", "Redis"],
    "test_framework": "pytest",
    "ci_platform": "GitHub Actions"
  },

  "commands": {
    "quality_check": {
      "primary": "make quality",
      "description": "运行所有代码质量检查",
      "tools": ["black", "flake8", "mypy", "bandit", "radon", "vulture"]
    },
    "format_code": {
      "primary": "make format",
      "description": "使用black格式化代码"
    },
    "run_tests": {
      "primary": "make test",
      "description": "运行单元测试",
      "count": 279,
      "v2_tests": 51
    },
    "coverage_analysis": {
      "primary": "make coverage",
      "description": "运行测试并生成覆盖率报告",
      "target": 80
    },
    "ci_simulation": {
      "primary": "make ci",
      "description": "完整CI模拟",
      "steps": ["env-check", "quality", "test", "coverage"]
    },
    "docker_testing": {
      "primary": "./scripts/docker-manager.sh test",
      "description": "在Docker容器中运行测试"
    },
    "local_ci_verify": {
      "primary": "./ci-verify.sh",
      "description": "本地CI验证脚本"
    }
  },

  "file_patterns": {
    "source": ["src/**/*.py", "scripts/**/*.py"],
    "tests": ["tests/**/*.py"],
    "config": ["pyproject.toml", "setup.cfg", ".flake8", "mypy.ini"],
    "exclude": ["*/migrations/*", "*/venv/*", "*/__pycache__/*"]
  },

  "quality_metrics": {
    "coverage": {
      "target": 80,
      "current": "varies_by_category"
    },
    "complexity": {
      "max_cc": 10,
      "tool": "radon"
    },
    "security": {
      "tool": "bandit",
      "confidence": "medium"
    },
    "type_checking": {
      "tool": "mypy",
      "strictness": "standard"
    }
  },

  "integration_points": {
    "makefile": 27,
    "docker_compose": true,
    "github_actions": true,
    "pre_commit": true,
    "local_scripts": ["ci-verify.sh", "docker-manager.sh"]
  },

  "known_issues": [
    {
      "issue": "V2测试跳过",
      "count": 22,
      "causes": ["Redis连接", "数据库连接", "模型文件缺失"],
      "solution": "启动完整Docker环境"
    },
    {
      "issue": "Git状态",
      "status": "多个文件staging",
      "action_needed": "提交或重置"
    },
    {
      "issue": "测试文件名冲突",
      "problem": "test_services_v2.py在多个目录重复",
      "solution": "已重命名legacy/test_services_v2.py为test_services_v2_legacy.py"
    },
    {
      "issue": "MyPy类型检查错误",
      "problem": "src.services模块路径冲突",
      "solution": "已重构services目录结构，分离base_service.py和service_manager.py"
    }
  ],

  "improvement_focus": [
    "提升测试稳定性",
    "重新启用CI测试功能",
    "提升代码覆盖率到80%+",
    "清理Git状态"
  ]
}