  "implementation_templates": {
    "decimal_odds_conversion": {
      "template": "from decimal import Decimal, getcontext\n\ngetcontext().prec = 28\ngetcontext().rounding = ROUND_HALF_EVEN\n\ndef safe_odds_to_probability(odds: Union[float, Decimal]) -> Decimal:\n    \"\"\"Convert odds to probability with high precision\"\"\"\n    if odds <= 0:\n        raise ValueError(f\"Invalid odds: {odds}\")\n    return Decimal(1) / Decimal(str(odds))",
      "benefits": ["precision_guarantee", "error_tracking", "audit_trail"]
    },

    "stable_probability_normalization": {
      "template": "def normalize_probabilities_stable(probs: List[float]) -> np.ndarray:\n    \"\"\"Numerically stable probability normalization\"\"\"\n    probs_array = np.array(probs, dtype=np.float64)\n    \n    # Use log-domain for numerical stability\n    log_probs = np.log(probs_array + 1e-15)  # Small epsilon to avoid log(0)\n    \n    # Subtract maximum for stability (log-sum-exp trick)\n    max_log = np.max(log_probs)\n    shifted_log_probs = log_probs - max_log\n    \n    # Normalize in log domain and convert back\n    normalized_log_probs = shifted_log_probs - np.log(np.sum(np.exp(shifted_log_probs)))\n    \n    return np.exp(normalized_log_probs)",
      "benefits": ["overflow_protection", "underflow_protection", "precision_preservation"]
    }
  },

