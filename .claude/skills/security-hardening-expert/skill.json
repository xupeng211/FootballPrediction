  "security_standards": {
    "frameworks": ["OWASP Top 10", "NIST Cybersecurity Framework", "ISO 27001"],
    "compliance": ["GDPR", "SOC 2", "PCI DSS (if applicable)"],
    "risk_levels": {
      "critical": "Data breach, system compromise",
      "high": "Authentication bypass, privilege escalation",
      "medium": "Information disclosure, denial of service",
      "low": "Configuration issues, information leakage"
    }
  },

  "vulnerability_categories": {
    "hardcoded_secrets": {
      "description": "API keys, passwords, tokens hardcoded in source",
      "risk_level": "critical",
      "detection_patterns": [
        "api_key", "secret", "password", "token",
        "database_connection_string", "private_key"
      ],
      "files_at_risk": [
        "src/config.py",
        "src/api/*.py",
        "src/services/*.py",
        "environment_files"
      ]
    },

    "insecure_communications": {
      "description": "Unencrypted data transmission, weak SSL/TLS",
      "risk_level": "high",
      "detection_areas": [
        "HTTP requests without verification",
        "Database connections without SSL",
        "API calls without certificate validation"
      ]
    },

    "input_validation": {
      "description": "Missing input sanitization and validation",
      "risk_level": "high",
      "vectors": [
        "SQL injection",
        "XSS attacks",
        "Path traversal",
        "Command injection"
      ]
    },

    "error_disclosure": {
      "description": "Sensitive information leaked through error messages",
      "risk_level": "medium",
      "concerns": [
        "Stack traces in production",
        "Database structure disclosure",
        "Internal system information"
      ]
    }
  },

  "hardening_strategies": {
    "secret_management": {
      "approach": "environment_variables + secure vault",
      "implementation": {
        "immediate": "Move all secrets to environment variables",
        "production": "Implement HashiCorp Vault or AWS Secrets Manager",
        "rotation": "Automated secret rotation policies"
      },
      "tools": ["python-dotenv", "cryptography", "keyring"]
    },

    "secure_communications": {
      "approach": "enforce TLS 1.2+ and certificate validation",
      "implementation": {
        "database": "sslmode=require certificate validation",
        "api_calls": "certificate verification + request signing",
        "internal_services": "mTLS for service-to-service communication"
      }
    },

    "input_validation": {
      "approach": "defense-in-depth validation strategy",
      "layers": [
        "API schema validation",
        "Business rule validation",
        "Database parameter validation",
        "Output encoding"
      ],
      "tools": ["pydantic", "sqlalchemy parameterized queries", "bleach"]
    },

    "error_handling": {
      "approach": "secure by default error handling",
      "implementation": {
        "production_logging": "Log structured, sanitized errors",
        "user_messages": "Generic error messages",
        "debug_info": "Only in development environments"
      }
    }
  },

