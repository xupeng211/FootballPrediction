{
  "skills": {
    "enabled": true,
    "autoLoad": true,
    "priority": [
      "football-prediction",
      "data-collection",
      "report-generation",
      "performance-monitoring",
      "infrastructure-optimization",
      "network-troubleshooting",
      "database-performance"
    ]
  },
  "mcpServers": {
    "postgres": {
      "command": "python",
      "args": ["mcp_servers/postgres_server.py"],
      "env": {
        "DB_HOST": "${DB_HOST}",
        "DB_PORT": "${DB_PORT}",
        "DB_NAME": "${DB_NAME}",
        "DB_USER": "${DB_USER}",
        "DB_PASSWORD": "${DB_PASSWORD}"
      },
      "description": "PostgreSQL database server for football prediction system"
    },
    "redis": {
      "command": "python",
      "args": ["mcp_servers/redis_server.py"],
      "env": {
        "REDIS_HOST": "${REDIS_HOST}",
        "REDIS_PORT": "${REDIS_PORT}",
        "REDIS_DB": "${REDIS_DB}",
        "REDIS_PASSWORD": "${REDIS_PASSWORD:-}"
      },
      "description": "Redis cache server for performance optimization"
    },
    "filesystem": {
      "command": "python",
      "args": ["mcp_servers/filesystem_server.py"],
      "description": "File system access for project management"
    },
    "system-monitor": {
      "command": "python",
      "args": ["mcp_servers/system_monitor_server.py"],
      "description": "System performance monitoring and infrastructure analysis",
      "env": {
        "PYTHONPATH": "${PWD}"
      }
    }
  },
  "permissions": {
    "allowedTools": [
      "Read(**/*.{js,ts,json,md,py,yml,yaml})",
      "Edit(**/*.{js,ts,py,json,md})",
      "Bash(python:*scripts/*)",
      "Bash(python:*src/*)",
      "Bash(make:*)",
      "Bash(git:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*ps)",
      "Bash(docker:*logs)",
      "Bash(curl:*localhost*)",
      "Bash(ls:*)",
      "Bash(find:*.py)",
      "Bash(grep:*.py)",
      "Bash(head:*config*)",
      "Bash(tail:*log*)"
    ],
    "deniedTools": [
      "Bash(rm -rf:*)",
      "Edit(**/secrets.json)",
      "Edit(**/.env*)"
    ]
  },
  "project": {
    "name": "Football Prediction System",
    "description": "Enterprise AI football prediction platform with Service Layer v2.0 architecture",
    "version": "2.0.0-Stable",
    "type": "machine-learning",
    "framework": "fastapi"
  },
  "environment": {
    "python_version": "3.11+",
    "primary_language": "python",
    "architecture": "microservices",
    "database": "postgresql",
    "cache": "redis",
    "monitoring": "prometheus-grafana"
  },
  "tools": {
    "development": [
      "pytest",
      "black",
      "flake8",
      "mypy",
      "coverage"
    ],
    "deployment": [
      "docker",
      "docker-compose",
      "kubernetes"
    ],
    "ml": [
      "xgboost",
      "pandas",
      "numpy",
      "scikit-learn",
      "shap"
    ]
  }
}