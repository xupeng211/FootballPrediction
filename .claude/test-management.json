{
  "test_strategy": "FootballPrediction v2.0",
  "last_updated": "2025-12-17",

  "test_structure": {
    "categories": {
      "v2_tests": {
        "path": "tests/v2/",
        "description": "v2.0架构的新测试",
        "total_count": 51,
        "passing": 29,
        "skipped": 22,
        "priority": "high",
        "focus_areas": [
          "inference_logic",
          "health_schema",
          "service_layer",
          "ml_features",
          "api_endpoints"
        ]
      },
      "unit_tests": {
        "path": "tests/unit/",
        "description": "单元测试",
        "focus": "业务逻辑单元测试",
        "integration_with": "pytest"
      },
      "integration_tests": {
        "path": "tests/integration/",
        "description": "集成测试",
        "focus": "数据库和外部API集成",
        "dependencies": ["PostgreSQL", "Redis", "FotMob API"]
      },
      "e2e_tests": {
        "path": "tests/e2e/",
        "description": "端到端测试",
        "focus": "完整工作流测试"
      },
      "performance_tests": {
        "path": "tests/performance/",
        "description": "性能测试",
        "focus": "响应时间、吞吐量、并发"
      }
    }
  },

  "test_execution_commands": {
    "quick_tests": {
      "command": "make test",
      "description": "快速运行单元测试",
      "expected_time": "< 2 minutes"
    },
    "coverage_tests": {
      "command": "make coverage",
      "description": "运行测试并生成覆盖率报告",
      "target_coverage": 80,
      "report_location": "htmlcov/index.html"
    },
    "complete_ci": {
      "command": "make ci",
      "description": "完整CI模拟（环境检查+质量检查+测试+覆盖率）",
      "includes": ["env-check", "quality", "test", "coverage"]
    },
    "docker_tests": {
      "command": "./scripts/docker-manager.sh test",
      "description": "在Docker容器中运行测试",
      "prerequisites": ["docker-compose up -d", "等待服务就绪"]
    },
    "specific_tests": {
      "v2_only": "pytest tests/v2/ -v",
      "health_check": "pytest tests/v2/test_health_schema.py::test_health_check_response -v",
      "inference_test": "pytest tests/v2/test_inference_logic.py::test_single_match_prediction -v",
      "smoke_tests": "pytest tests/ -k \"smoke\" -v"
    }
  },

  "test_dependencies": {
    "external_services": {
      "postgresql": {
        "purpose": "主数据库测试",
        "connection_check": "docker-compose exec db pg_isready -U football_user",
        "required_for": ["integration_tests", "e2e_tests"]
      },
      "redis": {
        "purpose": "缓存和队列测试",
        "required_for": ["v2_tests", "service_layer_tests"]
      },
      "fotmob_api": {
        "purpose": "外部API数据收集测试",
        "config": "FOTMOB_X_MAS_HEADER, FOTMOB_X_FOO_HEADER",
        "optional": true
      }
    },
    "model_files": {
      "required_for": ["inference_tests", "prediction_tests"],
      "location": "models/",
      "fallback": "使用模拟模型进行测试"
    }
  },

  "common_test_issues": {
    "v2_test_skipping": {
      "causes": [
        "缺少Redis连接",
        "数据库连接失败",
        "模型文件不存在",
        "外部API配置缺失"
      ],
      "solutions": [
        "启动完整Docker环境：docker-compose up -d",
        "等待服务就绪：sleep 30",
        "检查配置文件：.env.dev",
        "运行环境检查：make env-check"
      ]
    },
    "legacy_test_failures": {
      "causes": [
        "数据库依赖问题",
        "过时的测试数据",
        "API变更"
      ],
      "strategy": "优先关注V2测试，逐步修复遗留测试"
    }
  },

  "coverage_targets": {
    "overall_target": 80,
    "critical_modules": {
      "src/services/": 90,
      "src/ml/inference/": 85,
      "src/api/": 85,
      "src/ml/features/": 80
    },
    "exclusions": [
      "tests/",
      "*/migrations/*",
      "*/venv/*",
      "*/__pycache__/*"
    ]
  },

  "test_data_management": {
    "fixtures": "tests/fixtures/",
    "mock_data": "tests/mock_data/",
    "database_seeding": "scripts/test_seed_data.py",
    "api_mocking": "tests/mocks/"
  },

  "continuous_integration": {
    "github_actions": ".github/workflows/",
    "local_verification": "./ci-verify.sh",
    "pre_commit_hooks": [
      "pytest --co -q",  # 检查测试收集
      "pytest tests/v2/ --tb=short"  # 快速V2测试
    ]
  },

  "test_reporting": {
    "junit_xml": "reports/test-results.xml",
    "html_report": "reports/test-report.html",
    "coverage_html": "htmlcov/index.html",
    "performance_metrics": "reports/performance.json"
  },

  "test_environment_setup": {
    "development": ".env.dev",
    "ci": ".env.ci",
    "docker": ".env.docker",
    "setup_script": "./scripts/docker-manager.sh dev"
  }
}