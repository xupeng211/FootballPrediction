#!/usr/bin/env python3
"""
V41.230 Production Entry - 赔率数据同步服务
============================================

核心功能：
    - 生产级数据采集入口
    - 矩阵数据提取与序列对齐
    - 数据库自动映射与存储
    - 完整的审计日志

技术架构：
    - IndustrialAuditor: 内容审计与数据提取
    - SequenceProcessor: 三位一组序列切片
    - MatchLinker: 队名相似度匹配与数据库映射

Usage:
    # 基础运行 (V41.236: 从 bin/ 执行)
    ./bin/odds_sync --url "https://example.com/match-page"

    # 指定模式
    ./bin/odds_sync --url "..." --patterns "Opening" "Closing"

    # 禁用无头模式（调试）
    ./bin/odds_sync --url "..." --no-headless

    # 指定代理端口
    ./bin/odds_sync --url "..." --proxy-port 7893

    # 仅提取数据（不存储）
    ./bin/odds_sync --url "..." --extract-only

Production Deployment:
    # 后台运行
    nohup ./bin/odds_sync --url "..." > logs/odds_sync.log 2>&1 &

    # 定时任务 (crontab)
    0 */4 * * * cd /path/to/FootballPrediction && ./bin/odds_sync --url "..."

Author: V41.236 Engineering Team
Date: 2026-01-19
Version: V41.236 "Master Branch Convergence"
License: Production Ready
"""

from __future__ import annotations

import asyncio
import json
import logging
import sys
from dataclasses import replace
from datetime import datetime
from pathlib import Path
from typing import Any

# 项目路径 (V41.236: 从 bin/ 执行时回到项目根目录)
project_root = Path(__file__).parent.parent
sys.path.insert(0, str(project_root))

from src.config_unified import get_config
from src.core.scrapers.industrial_auditor import (
    IndustrialAuditor,
    AuditorConfig,
    ExtractionResult,
)
from src.services.match_linker import MatchLinker, LinkerConfig

# =============================================================================
# 日志配置 (统一格式)
# =============================================================================


def setup_logging(log_level: str = "INFO") -> logging.Logger:
    """
    配置统一日志格式

    格式: [TIMESTAMP] [LEVEL] [MODULE]: MESSAGE
    """
    log_dir = Path("logs")
    log_dir.mkdir(exist_ok=True)

    log_file = log_dir / f"odds_sync_{datetime.now().strftime('%Y%m%d')}.log"

    logging.basicConfig(
        level=getattr(logging, log_level.upper()),
        format="[%(asctime)s] [%(levelname)s] [%(name)s]: %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
        handlers=[
            logging.FileHandler(log_file, encoding="utf-8"),
            logging.StreamHandler(sys.stdout),
        ],
    )

    return logging.getLogger("OddsSync")


logger = setup_logging()


# =============================================================================
# 生产服务类 (Production Service)
# =============================================================================


class OddsSyncService:
    """
    V41.230 赔率同步服务

    完整流程：
    1. 访问目标页面
    2. 提取矩阵数据
    3. 序列对齐处理
    4. 数据库映射存储
    5. 生成审计报告
    """

    def __init__(
        self,
        auditor_config: AuditorConfig,
        linker_config: LinkerConfig,
        extract_only: bool = False,
    ):
        self.auditor_config = auditor_config
        self.linker_config = linker_config
        self.extract_only = extract_only

        self.auditor: IndustrialAuditor | None = None
        self.linker: MatchLinker | None = None
        self.result: ExtractionResult | None = None

    async def run(self) -> dict[str, Any]:
        """执行完整同步流程"""
        logger.info("=" * 60)
        logger.info("V41.230 Odds Sync Service - Starting")
        logger.info("=" * 60)
        logger.info(f"Target URL: {self.auditor_config.target_url}")
        logger.info(f"Extract Only: {self.extract_only}")
        logger.info("=" * 60)

        try:
            # 阶段 1: 数据提取
            logger.info("Phase 1: Data Extraction")
            self.auditor = IndustrialAuditor(self.auditor_config)
            self.result = await self.auditor.audit()

            logger.info(f"Extraction complete: {self.result.entities_extracted} entities")

            # 阶段 2: 数据存储（如果不是仅提取模式）
            if not self.extract_only:
                logger.info("Phase 2: Data Storage")
                await self._store_results()
            else:
                logger.info("Extract-only mode: skipping database storage")

            # 阶段 3: 生成报告
            logger.info("Phase 3: Report Generation")
            report = self._generate_report()

            logger.info("=" * 60)
            logger.info("V41.230 Odds Sync Service - Complete")
            logger.info("=" * 60)

            return report

        except Exception as e:
            logger.error(f"Sync failed: {e}", exc_info=True)
            raise

    async def _store_results(self) -> None:
        """存储结果到数据库"""
        if not self.result:
            logger.warning("No result to store")
            return

        self.linker = MatchLinker(self.linker_config)

        stored_count = 0

        # 注意：这里需要队名和时间信息才能关联
        # 实际使用时需要从页面或上下文中获取
        logger.info(f"Storage requires team names and match time for linking")
        logger.info(f"Use --extract-only for extraction without database storage")

        # 示例存储逻辑（需要完整信息）
        # for idx, entity in enumerate(self.result.entities):
        #     link_result = await self.linker.link_and_store(
        #         vector_data=entity.to_dict(),
        #         home_team=home_team,
        #         away_team=away_team,
        #         match_time=match_time,
        #     )
        #     if link_result.stored:
        #         stored_count += 1

        logger.info(f"Stored: {stored_count} entities")

    def _generate_report(self) -> dict[str, Any]:
        """生成同步报告"""
        if not self.result:
            return {}

        report = {
            "timestamp": datetime.now().isoformat(),
            "target_url": self.result.target_url,
            "entities_extracted": self.result.entities_extracted,
            "quality_distribution": {},
            "output_file": "",
        }

        # 统计质量分布
        for entity in self.result.entities:
            quality = entity.to_dict()["Quality_Rating"]
            report["quality_distribution"][quality] = (
                report["quality_distribution"].get(quality, 0) + 1
            )

        # 保存结果
        output_file = self.auditor.save_result() if self.auditor else None
        if output_file:
            report["output_file"] = str(output_file)

        return report


# =============================================================================
# 命令行入口
# =============================================================================


async def main_async():
    """异步命令行入口"""
    import argparse

    parser = argparse.ArgumentParser(
        description="V41.230 Production Odds Sync Service",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
    # Basic usage
    python run_odds_sync.py --url "https://example.com/match-page"

    # Custom patterns
    python run_odds_sync.py --url "..." --patterns "Opening" "Closing" "Movement"

    # Debug mode (non-headless)
    python run_odds_sync.py --url "..." --no-headless

    # Extract only (no database storage)
    python run_odds_sync.py --url "..." --extract-only

    # Custom proxy
    python run_odds_sync.py --url "..." --proxy-port 7893

    # Verbose logging
    python run_odds_sync.py --url "..." --log-level DEBUG
        """,
    )

    parser.add_argument(
        "--url",
        type=str,
        required=True,
        help="Target URL to extract odds data",
    )
    parser.add_argument(
        "--patterns",
        nargs="+",
        default=["Opening", "Closing", "Movement"],
        help="Search patterns for data extraction (default: Opening Closing Movement)",
    )
    parser.add_argument(
        "--no-headless",
        action="store_true",
        help="Disable headless mode (for debugging)",
    )
    parser.add_argument(
        "--proxy-port",
        type=int,
        default=7892,
        help="Proxy port to use (default: 7892)",
    )
    parser.add_argument(
        "--extract-only",
        action="store_true",
        help="Extract data only, skip database storage",
    )
    parser.add_argument(
        "--output",
        type=str,
        default="logs/industrial_audit_result.json",
        help="Output file path (default: logs/industrial_audit_result.json)",
    )
    parser.add_argument(
        "--log-level",
        type=str,
        default="INFO",
        choices=["DEBUG", "INFO", "WARNING", "ERROR"],
        help="Logging level (default: INFO)",
    )
    parser.add_argument(
        "--timeout",
        type=int,
        default=30000,
        help="Network idle timeout in milliseconds (default: 30000)",
    )

    args = parser.parse_args()

    # 更新日志级别
    global logger
    logger = setup_logging(args.log_level)

    # 验证 URL
    if not args.url.startswith(("http://", "https://")):
        parser.error(f"Invalid URL: {args.url}")

    # 创建配置
    config = get_config()
    auditor_config = AuditorConfig(
        target_url=args.url,
        target_patterns=args.patterns,
        headless=not args.no_headless,
        proxy_port=args.proxy_port,
        network_idle_timeout=args.timeout,
    )

    linker_config = LinkerConfig(
        time_window_hours=48.0,
        similarity_threshold=0.85,
    )

    # 执行同步
    service = OddsSyncService(
        auditor_config=auditor_config,
        linker_config=linker_config,
        extract_only=args.extract_only,
    )

    try:
        report = await service.run()

        # 输出摘要
        print("\n" + "=" * 60)
        print("Sync Summary")
        print("=" * 60)
        print(f"Target URL: {report.get('target_url', 'N/A')}")
        print(f"Entities Extracted: {report.get('entities_extracted', 0)}")
        print(f"Quality Distribution: {report.get('quality_distribution', {})}")
        if report.get('output_file'):
            print(f"Output File: {report['output_file']}")
        print("=" * 60 + "\n")

        return 0

    except Exception as e:
        logger.error(f"Service failed: {e}")
        return 1


def main():
    """命令行入口"""
    return asyncio.run(main_async())


if __name__ == "__main__":
    exit(main())
